---
import "../styles/global.css";
import { withBase } from "../lib/url";

interface Props {
  title: string;
  description?: string;
  hideTopbar?: boolean;
}

const {
  title,
  description = "Recopilación sin ánimo de lucro de noticias de Colombia y el mundo, indicadores económicos y recomendados sobre seguridad, justicia y paz.",
  hideTopbar = false,
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href={withBase("/cat-logo.png")} type="image/png" />
    <!-- Open Graph / WhatsApp / redes sociales -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="El Gato Lector" />
    <meta property="og:title" content={`${title} · El Gato Lector`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://viviana-cmyk.github.io/el-gato-lector-1/cat-logo.png" />
    <meta property="og:url" content="https://viviana-cmyk.github.io/el-gato-lector-1/" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={`${title} · El Gato Lector`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://viviana-cmyk.github.io/el-gato-lector-1/cat-logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=Poppins:wght@700;800;900&display=swap"
      rel="stylesheet"
    />
    <title>{title} · El Gato Lector</title>
    <slot name="head" />
  </head>
  <body>
    {!hideTopbar && (
      <header class="topbar">
        <div class="topbar__inner">
          <a class="topbar__brand" href={withBase("/")}>
            <img src={withBase("/cat-logo.png")} alt="" />
            El Gato Lector
          </a>
          <nav class="topbar__nav">
            <a class="pill" href={withBase("/")}>Inicio</a>
            <a class="pill" href={withBase("/actualidad")}>Actualidad</a>
            <a class="pill" href={withBase("/reflexiones")}>Reflexiones del Gato</a>
            <a class="pill" href={withBase("/cifras")}>Gato en Cifras</a>
            <a class="pill pill--ghost" href={withBase("/recomendados")}>Recomendados</a>
          </nav>
        </div>
      </header>
    )}

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="wrap">
        <span class="pin">📍</span>
        <div class="footer__brand">El Gato Lector</div>
        <p>
          Recopilación sin ánimo de lucro en temas de seguridad, justicia y paz, realizada
          desde la curiosidad innata de los gatos. <strong>Lee, actualízate y edifica</strong>
          tus propias conjeturas a partir de datos, tendencias y contemporaneidad.
        </p>
        <img class="footer__cat" src={withBase("/cat-logo.png")} alt="El Gato Lector" />
      </div>
    </footer>
  </body>
  <script>
    if (history.scrollRestoration) history.scrollRestoration = "manual";
    window.scrollTo({ top: 0, left: 0, behavior: "instant" });
  </script>
</html>
