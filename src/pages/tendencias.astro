---
import Layout from "../layouts/Layout.astro";
import RankList from "../components/RankList.astro";
import UpdatedNote from "../components/UpdatedNote.astro";
import curated from "../data/curated.json";
import featured from "../data/featured.json";
import podcastData from "../data/podcasts.json";
import trendsData from "../data/trends.json";

// Tendencias desde Google Trends (auto) con fallback a curated.json (manual)
const trendsCO = (trendsData as any).colombia?.length ? (trendsData as any).colombia : curated.tendencias.redes[0]?.top5 ?? [];
const trendsMundo = (trendsData as any).mundo?.length ? (trendsData as any).mundo : curated.tendencias.redes[2]?.top5 ?? [];

const redes = [
  { platform: "Colombia", top5: trendsCO },
  { platform: "Mundo",    top5: trendsMundo },
];
const podcasts = {
  colombia: podcastData.colombia?.length ? podcastData.colombia : curated.tendencias.podcasts.colombia,
  mundo: podcastData.mundo?.length ? podcastData.mundo : curated.tendencias.podcasts.mundo,
};

const platformIcons: Record<string, string> = {
  Colombia: "🇨🇴",
  Mundo: "🌍",
};

function hashtagUrl(platform: string, tag: string): string {
  const clean = tag.replace(/^#/, "");
  return `https://trends.google.com/trending?geo=${platform === "Colombia" ? "CO" : "US"}&q=${encodeURIComponent(clean)}`;
}

function podcastUrl(title: string, url?: string): string {
  if (url) return url;
  return `https://podcasts.apple.com/search?term=${encodeURIComponent(title)}`;
}

const redesLists = redes.map((red) => ({
  title: `${red.platform} · Top 5`,
  icon: platformIcons[red.platform] ?? "📈",
  items: red.top5.map((tag) => ({ primary: tag, url: hashtagUrl(red.platform, tag) })),
}));

const podcastLists = [
  { label: "Colombia", icon: "🎙️", items: podcasts.colombia },
  { label: "Mundo", icon: "🌍", items: podcasts.mundo },
].map((group) => ({
  title: `Ranking podcasts · ${group.label}`,
  icon: group.icon,
  items: group.items.map((podcast) => ({
    primary: podcast.title,
    secondary: podcast.host,
    url: podcastUrl(podcast.title, podcast.url),
  })),
}));
---

<Layout
  title="Tendencias"
  description="Top 5 tendencias del día en TikTok, Instagram y X, y el ranking de podcasts más escuchados en Colombia y el mundo."
>
  <section class="section wrap">
    <h2 class="section__title">Tendencias</h2>
    <p class="section__byline">El Gato Lector</p>

    <div class="trends">
      <div class="trends__header">
        <span class="trends__live">● EN VIVO</span>
        <span class="trends__subtitle">
          Lo que se conversa hoy en redes sobre Colombia y el mundo
        </span>
      </div>

      <div class="rank-sections">
        {redesLists.map((list) => <RankList title={list.title} icon={list.icon} items={list.items} />)}
        {podcastLists.map((list) => <RankList title={list.title} icon={list.icon} items={list.items} />)}
      </div>
    </div>

    <UpdatedNote generatedAt={featured.generatedAt} />
  </section>
</Layout>
