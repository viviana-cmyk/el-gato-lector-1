---
import Layout from "../layouts/Layout.astro";
import IndicatorsBar from "../components/IndicatorsBar.astro";
import UpdatedNote from "../components/UpdatedNote.astro";
import FeaturedStory from "../components/FeaturedStory.astro";
import WeatherSection from "../components/WeatherSection.astro";
import WorldCup from "../components/WorldCup.astro";
import { withBase } from "../lib/url";
import featured from "../data/featured.json";
import dailyinfo from "../data/dailyinfo.json";

const diaHoy = (dailyinfo as any).dia ?? null;
---

<Layout title="Inicio" hideTopbar>
  <section class="hero" style={`background-image: linear-gradient(180deg, rgba(5,5,8,0.65) 0%, rgba(5,5,8,0.82) 55%, rgba(5,5,8,0.97) 100%), url('${withBase('/biblioteca.webp')}')`}>
    <div class="hero__inner">
      <img class="hero__cat" src={withBase("/cat-logo.png")} alt="El Gato Lector" />

      <div class="hero__badge">● Actualizado cada día a las 5:00 a.m.</div>

      <h1>El Gato <span>Lector</span></h1>

      <p class="subtitle">Noticias priorizadas por relevancia · Colombia y el mundo</p>

      <nav class="hero__nav">
        <a class="pill hero__pill--primary" href={withBase("/colombia")}>🇨🇴 Colombia</a>
        <a class="pill hero__pill--primary" href={withBase("/mundo")}>🌍 El Mundo</a>
        <a class="pill hero__pill--primary" href={withBase("/reflexiones")}>✦ Reflexiones del Gato</a>
        <a class="pill pill--ghost" href={withBase("/tendencias")}>Tendencias</a>
        <a class="pill pill--ghost" href={withBase("/recomendados")}>Recomendados</a>
      </nav>

      {diaHoy && (
        <div class="hero__diainfo">
          <span class="hero__diainfo-icon">📅</span>
          <div class="hero__diainfo-body">
            <span class="hero__diainfo-title">{diaHoy.nombre}</span>
            <span class="hero__diainfo-desc">{diaHoy.descripcion}</span>
          </div>
        </div>
      )}
      {!diaHoy && (
        <div class="hero__stats">
          <div class="hero__stat"><span class="hero__stat-num">8+</span><span class="hero__stat-label">Medios Colombia</span></div>
          <div class="hero__stat-div"></div>
          <div class="hero__stat"><span class="hero__stat-num">8+</span><span class="hero__stat-label">Medios Mundo</span></div>
          <div class="hero__stat-div"></div>
          <div class="hero__stat"><span class="hero__stat-num">IA</span><span class="hero__stat-label">Priorización temática</span></div>
          <div class="hero__stat-div"></div>
          <div class="hero__stat"><span class="hero__stat-num">5AM</span><span class="hero__stat-label">Actualización diaria</span></div>
        </div>
      )}
    </div>
  </section>

  <section id="inicio-contenido" class="section wrap">
    <h2 class="section__title">La noticia del día</h2>
    <p class="section__byline">El Gato Lector</p>
    <FeaturedStory />
  </section>

  <section class="section wrap">
    <h2 class="section__title">Indicadores económicos</h2>
    <p class="section__byline">El Gato Lector</p>
    <IndicatorsBar />
  </section>

  <section class="section wrap">
    <h2 class="section__title">Clima · principales ciudades</h2>
    <p class="section__byline">El Gato Lector</p>
    <WeatherSection />
  </section>

  <section class="section wrap">
    <h2 class="section__title">Mundial 2026 · Partidos</h2>
    <p class="section__byline">El Gato Lector</p>
    <WorldCup />
  </section>

  <div class="wrap">
    <UpdatedNote generatedAt={featured.generatedAt} />
  </div>
</Layout>

<script>
  document.getElementById("inicio-contenido")?.scrollIntoView({ behavior: "instant" });
</script>
