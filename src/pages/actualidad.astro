---
import Layout from "../layouts/Layout.astro";
import IndicatorsBar from "../components/IndicatorsBar.astro";
import NewsGrid from "../components/NewsGrid.astro";
import RankList from "../components/RankList.astro";
import UpdatedNote from "../components/UpdatedNote.astro";
import colombiaData from "../data/news-colombia.json";
import mundoData from "../data/news-mundo.json";
import trendsData from "../data/trends.json";
import podcastData from "../data/podcasts.json";
import curated from "../data/curated.json";
import tensionesData from "../data/tensiones.json";
import latamData from "../data/news-latam.json";

const td = trendsData as any;

function hashtagUrl(network: string, tag: string): string {
  const clean = tag.replace(/^#/, "");
  if (network === "tiktok") return `https://www.tiktok.com/tag/${encodeURIComponent(clean)}`;
  return `https://x.com/hashtag/${encodeURIComponent(clean)}`;
}
function podcastUrl(title: string, url?: string): string {
  if (url) return url;
  return `https://podcasts.apple.com/search?term=${encodeURIComponent(title)}`;
}

// ── Tendencias Colombia ───────────────────────────────────────────────────────
const redesColombia = [
  { title: "Colombia · Top 5",          icon: "𝕏",  network: "x",      tags: td.x?.colombia      ?? [] },
  { title: "TikTok · Colombia · Top 5", icon: "🎵", network: "tiktok", tags: td.tiktok?.colombia ?? [] },
]
  .filter((r) => r.tags.length > 0)
  .map((r) => ({
    title: r.title, icon: r.icon,
    items: r.tags.map((tag: string) => ({ primary: tag, url: hashtagUrl(r.network, tag) })),
  }));

const podcastsColombia = (podcastData as any).colombia?.length
  ? (podcastData as any).colombia
  : (curated as any).tendencias.podcasts.colombia;

const podcastListColombia = {
  title: "Ranking podcasts · Colombia", icon: "🎙️",
  items: podcastsColombia.map((p: any) => ({
    primary: p.title, secondary: p.host, url: podcastUrl(p.title, p.url),
  })),
};

// ── Tendencias Mundo ──────────────────────────────────────────────────────────
const redesMundo = [
  { title: "Mundo · Top 5",          icon: "𝕏",  network: "x",      tags: td.x?.mundo      ?? [] },
  { title: "TikTok · Mundo · Top 5", icon: "🎵", network: "tiktok", tags: td.tiktok?.mundo ?? [] },
]
  .filter((r) => r.tags.length > 0)
  .map((r) => ({
    title: r.title, icon: r.icon,
    items: r.tags.map((tag: string) => ({ primary: tag, url: hashtagUrl(r.network, tag) })),
  }));

const podcastsMundo = (podcastData as any).mundo?.length
  ? (podcastData as any).mundo
  : (curated as any).tendencias.podcasts.mundo;

const podcastListMundo = {
  title: "Ranking podcasts · Mundo", icon: "🌍",
  items: podcastsMundo.map((p: any) => ({
    primary: p.title, secondary: p.host, url: podcastUrl(p.title, p.url),
  })),
};
---

<Layout
  title="Actualidad"
  description="Noticias de Colombia y el mundo: Semana, El Espectador, El Tiempo, CNN, El País, The Guardian y más, actualizadas a diario."
>
  <section class="section wrap">
    <h2 class="section__title">Actualidad</h2>
    <p class="section__byline">Noticias</p>

    <!-- Selector de región -->
    <div class="act-tabs" role="tablist">
      <button class="act-tab act-tab--active" role="tab" data-panel="colombia" aria-selected="true">
        Colombia
      </button>
      <button class="act-tab" role="tab" data-panel="latam" aria-selected="false">
        Latinoamérica
      </button>
      <button class="act-tab" role="tab" data-panel="mundo" aria-selected="false">
        El Mundo
      </button>
      <button class="act-tab" role="tab" data-panel="tensiones" aria-selected="false">
        TOP 3 · Tensiones
      </button>
    </div>

    <!-- ── Panel Colombia ──────────────────────────────────────────────── -->
    <div id="panel-colombia" class="act-panel" role="tabpanel">
      <IndicatorsBar />
      <NewsGrid outlets={colombiaData.outlets} />

      {(redesColombia.length > 0 || podcastListColombia.items.length > 0) && (
        <div class="trends" style="margin-top:2.5rem">
          <h2 class="section__title" style="margin-bottom:0.5rem">Tendencias</h2>
          <div class="trends__header">
            <span class="trends__live">● EN VIVO</span>
            <span class="trends__subtitle">Tendencias de hoy en Colombia</span>
          </div>
          <div class="rank-sections">
            {redesColombia.map((list) => (
              <RankList title={list.title} icon={list.icon} items={list.items} />
            ))}
            {podcastListColombia.items.length > 0 && (
              <RankList title={podcastListColombia.title} icon={podcastListColombia.icon} items={podcastListColombia.items} />
            )}
          </div>
        </div>
      )}

      <UpdatedNote generatedAt={colombiaData.generatedAt} />
    </div>

    <!-- ── Panel Latinoamérica ───────────────────────────────────────── -->
    <div id="panel-latam" class="act-panel act-panel--hidden" role="tabpanel">
      <NewsGrid outlets={latamData.outlets} />
      <UpdatedNote generatedAt={latamData.generatedAt} />
    </div>

    <!-- ── Panel El Mundo ─────────────────────────────────────────────── -->
    <div id="panel-mundo" class="act-panel act-panel--hidden" role="tabpanel">
      <NewsGrid outlets={mundoData.outlets} />

      {(redesMundo.length > 0 || podcastListMundo.items.length > 0) && (
        <div class="trends" style="margin-top:2.5rem">
          <h2 class="section__title" style="margin-bottom:0.5rem">Tendencias</h2>
          <div class="trends__header">
            <span class="trends__live">● EN VIVO</span>
            <span class="trends__subtitle">Tendencias de hoy en el mundo</span>
          </div>
          <div class="rank-sections">
            {redesMundo.map((list) => (
              <RankList title={list.title} icon={list.icon} items={list.items} />
            ))}
            {podcastListMundo.items.length > 0 && (
              <RankList title={podcastListMundo.title} icon={podcastListMundo.icon} items={podcastListMundo.items} />
            )}
          </div>
        </div>
      )}

      <UpdatedNote generatedAt={mundoData.generatedAt} />
    </div>

    <!-- ── Panel Tensiones Globales ──────────────────────────────────── -->
    <div id="panel-tensiones" class="act-panel act-panel--hidden" role="tabpanel">
      <div class="tensiones-header">
        <span class="tensiones-badge">● EN VIVO</span>
        <span class="tensiones-sub">Conflictos y tensiones geopolíticas con mayor impacto global hoy</span>
      </div>

      <div class="tensiones-list">
        {(tensionesData as any).tensiones.map((t: any) => (
          <article class="tension-card">
            <div class="tension-rank">#{t.rank}</div>
            <div class="tension-body">
              <div class="tension-meta">
                <span class="tension-titulo">{t.titulo}</span>
                <span class="tension-region">{t.region}</span>
              </div>
              <p class="tension-analisis">{t.analisis}</p>
              {t.noticia?.link && t.noticia.link !== "#" && (
                <a class="tension-noticia" href={t.noticia.link} target="_blank" rel="noopener">
                  <span class="tension-noticia__fuente">{t.noticia.fuente}</span>
                  <span class="tension-noticia__titulo">{t.noticia.titulo}</span>
                </a>
              )}
            </div>
          </article>
        ))}
      </div>

      <UpdatedNote generatedAt={(tensionesData as any).generatedAt} />
    </div>
  </section>
</Layout>

<style>
.act-tabs {
  display: flex;
  gap: 0;
  margin: 1.75rem 0 0;
  border-bottom: 2px solid var(--border);
}
.act-tab {
  background: transparent;
  border: none;
  border-bottom: 3px solid transparent;
  margin-bottom: -2px;
  padding: 0.65rem 1.75rem;
  font-size: 0.92rem;
  font-weight: 700;
  color: var(--ink-soft);
  cursor: pointer;
  letter-spacing: 0.03em;
  font-family: var(--font-body);
  transition: color 0.15s, border-color 0.15s;
}
.act-tab:hover { color: var(--ink); }
.act-tab--active {
  color: var(--accent);
  border-bottom-color: var(--accent);
}
.act-panel { padding-top: 1.75rem; }
.act-panel--hidden { display: none; }

/* ── Tensiones Globales ─────────────────────────────────────────────────── */
.tensiones-header {
  display: flex; align-items: center; gap: 0.75rem;
  margin-bottom: 1.5rem;
}
.tensiones-badge {
  font-size: 0.65rem; font-weight: 800; letter-spacing: 0.08em;
  color: #e07060; text-transform: uppercase;
}
.tensiones-sub {
  font-size: 0.78rem; color: var(--ink-soft);
}
.tensiones-list {
  display: flex; flex-direction: column; gap: 1.25rem;
  max-width: 780px;
}
.tension-card {
  display: flex; gap: 1.25rem; align-items: flex-start;
  background: var(--surface-2); border: 1px solid rgba(255,255,255,0.07);
  border-radius: var(--radius); padding: 1.25rem 1.5rem;
  position: relative; overflow: hidden;
  box-shadow: 0 4px 18px rgba(0,0,0,0.32);
  transition: border-color 0.25s, box-shadow 0.25s;
}
.tension-card::before {
  content: ""; position: absolute;
  bottom: -30px; left: 50%; transform: translateX(-50%);
  width: 300px; height: 120px;
  background: radial-gradient(ellipse, rgba(230,179,0,0.08) 0%, transparent 70%);
  opacity: 0; transition: opacity 0.35s; pointer-events: none;
}
.tension-card:hover::before { opacity: 1; }
.tension-card:hover {
  border-color: rgba(230,179,0,0.18);
  box-shadow: 0 6px 26px rgba(0,0,0,0.42);
}
.tension-rank {
  font-family: var(--font-display); font-size: 2rem; font-weight: 900;
  color: rgba(230,179,0,0.35); line-height: 1; flex-shrink: 0;
  min-width: 2.5rem; text-align: center; margin-top: 0.1rem;
}
.tension-body { flex: 1; display: flex; flex-direction: column; gap: 0.6rem; }
.tension-meta { display: flex; align-items: baseline; gap: 0.75rem; flex-wrap: wrap; }
.tension-titulo {
  font-size: 1rem; font-weight: 800; color: var(--ink); letter-spacing: -0.01em;
}
.tension-region {
  font-size: 0.68rem; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.07em; color: var(--ink-soft);
  background: rgba(255,255,255,0.06); padding: 0.15rem 0.5rem;
  border-radius: 999px;
}
.tension-analisis {
  font-size: 0.875rem; color: var(--ink-soft); line-height: 1.6; margin: 0;
}
.tension-noticia {
  display: flex; flex-direction: column; gap: 0.2rem;
  border-left: 2px solid rgba(230,179,0,0.4);
  padding-left: 0.75rem; text-decoration: none;
  transition: border-color 0.2s;
}
.tension-noticia:hover { border-color: rgba(230,179,0,0.8); }
.tension-noticia__fuente {
  font-size: 0.62rem; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.08em; color: var(--accent);
}
.tension-noticia__titulo {
  font-size: 0.8rem; color: var(--ink); line-height: 1.4;
}
.tension-noticia:hover .tension-noticia__titulo { color: var(--accent); }

@media (max-width: 480px) {
  .tension-rank { font-size: 1.5rem; min-width: 2rem; }
  .tension-card { padding: 1rem; gap: 0.75rem; }
}
</style>

<script>
  const tabs   = document.querySelectorAll<HTMLButtonElement>(".act-tab");
  const panels = document.querySelectorAll<HTMLElement>(".act-panel");

  function activar(panel: string) {
    tabs.forEach((t) => {
      const active = t.dataset.panel === panel;
      t.classList.toggle("act-tab--active", active);
      t.setAttribute("aria-selected", String(active));
    });
    panels.forEach((p) => {
      p.classList.toggle("act-panel--hidden", p.id !== `panel-${panel}`);
    });
  }

  // Activar por hash al cargar (#mundo o #colombia)
  const hash = location.hash.replace("#", "");
  if (hash === "mundo" || hash === "colombia") activar(hash);

  tabs.forEach((btn) => {
    btn.addEventListener("click", () => {
      const panel = btn.dataset.panel!;
      activar(panel);
      history.replaceState(null, "", `#${panel}`);
    });
  });
</script>
