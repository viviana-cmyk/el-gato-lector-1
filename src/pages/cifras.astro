---
import Layout from "../layouts/Layout.astro";
import cifrasData from "../data/cifras.data.json";

const data = cifrasData as any;
const meta = data.meta;

// Fechas
const cortePolicia = new Date(meta.corte_policia + 'T00:00:00-05:00')
  .toLocaleDateString("es-CO", { day: "numeric", month: "long", year: "numeric", timeZone: "America/Bogota" });
const generadoStr = new Date(meta.generatedAt)
  .toLocaleDateString("es-CO", { day: "numeric", month: "long", year: "numeric", timeZone: "America/Bogota" });

// Helpers para totales
const totalMunic = data.municipios.length;
const sum25 = (campo: string) => (data.municipios as any[]).reduce((s: number, m: any) => s + (m[campo].casos_2025_ene_abr ?? 0), 0);
const sum26 = (campo: string) => (data.municipios as any[]).reduce((s: number, m: any) => s + (m[campo].casos_2026_ene_abr ?? 0), 0);
const nacVar = (campo: string) => {
  const a = sum25(campo), b = sum26(campo);
  return a > 0 ? Math.round(((b - a) / a) * 1000) / 10 : null;
};

// Hero
const topTasa = [...data.municipios]
  .filter((m: any) => m.homicidio.tasa_2026_proyectada)
  .sort((a: any, b: any) => b.homicidio.tasa_2026_proyectada - a.homicidio.tasa_2026_proyectada)[0];

// Nacionales — 6 delitos
const homNac25ea = sum25('homicidio'),   homNac26ea = sum26('homicidio'),   homNacVar = nacVar('homicidio');
const hurNac25ea = sum25('hurto_personas'), hurNac26ea = sum26('hurto_personas'), hurNacVar = nacVar('hurto_personas');
const extNac25ea = sum25('extorsion'),   extNac26ea = sum26('extorsion'),   extNacVar = nacVar('extorsion');
const resNac25ea = sum25('hurto_residencias'), resNac26ea = sum26('hurto_residencias'), resNacVar = nacVar('hurto_residencias');
const vifNac25ea = sum25('violencia_intra'),   vifNac26ea = sum26('violencia_intra'),   vifNacVar = nacVar('violencia_intra');
const autNac25ea = sum25('hurto_automotores'), autNac26ea = sum26('hurto_automotores'), autNacVar = nacVar('hurto_automotores');

// Coordenadas de los 38 municipios
const COORDS: Record<string, [number, number]> = {
  "11001": [4.7110, -74.0721],   "05001": [6.2518, -75.5636],
  "76001": [3.4516, -76.5320],   "08001": [10.9685, -74.7813],
  "13001": [10.3997, -75.5144],  "54001": [7.8939, -72.5078],
  "68001": [7.1254, -73.1198],   "73001": [4.4389, -75.2322],
  "50001": [4.1420, -73.6266],   "47001": [11.2408, -74.1990],
  "66001": [4.8133, -75.6961],   "20001": [10.4631, -73.2532],
  "23001": [8.7575, -75.8831],   "52001": [1.2136, -77.2811],
  "17001": [5.0689, -75.5174],   "41001": [2.9273, -75.2820],
  "63001": [4.5339, -75.6811],   "19001": [2.4448, -76.6147],
  "70001": [9.3047, -75.3978],   "44001": [11.5444, -72.9072],
  "27001": [5.6919, -76.6583],   "15001": [5.5353, -73.3678],
  "18001": [1.6144, -75.6062],   "85001": [5.3378, -72.3956],
  "81001": [7.0846, -70.7583],   "86001": [1.1522, -76.6498],
  "88001": [12.5847, -81.7006],  "91001": [-4.2153, -69.9408],
  "94001": [3.8653, -67.9239],   "95001": [2.5637, -72.6399],
  "97001": [1.1983, -70.1742],   "99001": [6.1891, -67.4844],
  "25754": [4.5793, -74.2169],   "08758": [10.9183, -74.7669],
  "05088": [6.3292, -75.5576],   "76520": [3.5394, -76.3033],
  "05360": [6.1843, -75.5985],   "68276": [7.0636, -73.0937],
};

// cityData compacto — 6 delitos, todos Policía
const cityData = [...data.municipios]
  .sort((a: any, b: any) => a.municipio.localeCompare(b.municipio, "es"))
  .map((m: any) => {
    const coord = COORDS[m.divipola] ?? null;
    const f = (campo: string, k: string) => m[campo][k] ?? null;
    return {
      municipio: m.municipio,
      div: m.divipola,
      lat: coord?.[0] ?? null,
      lng: coord?.[1] ?? null,
      // homicidio
      h26: f('homicidio','casos_2026_ene_abr'),   h25: f('homicidio','casos_2025_ene_abr'),
      hv:  f('homicidio','variacion_pct_ene_abr'), hbp: m.homicidio.base_pequena,
      ht:  f('homicidio','tasa_2026_ene_abr'),     htp: f('homicidio','tasa_2026_proyectada'),
      // hurto personas
      u26: f('hurto_personas','casos_2026_ene_abr'),   u25: f('hurto_personas','casos_2025_ene_abr'),
      uv:  f('hurto_personas','variacion_pct_ene_abr'), ubp: m.hurto_personas.base_pequena,
      ut:  f('hurto_personas','tasa_2026_ene_abr'),     utp: f('hurto_personas','tasa_2026_proyectada'),
      // extorsión
      e26: f('extorsion','casos_2026_ene_abr'),   e25: f('extorsion','casos_2025_ene_abr'),
      ev:  f('extorsion','variacion_pct_ene_abr'), ebp: m.extorsion.base_pequena,
      et:  f('extorsion','tasa_2026_ene_abr'),     etp: f('extorsion','tasa_2026_proyectada'),
      // hurto residencias
      r26: f('hurto_residencias','casos_2026_ene_abr'),   r25: f('hurto_residencias','casos_2025_ene_abr'),
      rv:  f('hurto_residencias','variacion_pct_ene_abr'), rbp: m.hurto_residencias.base_pequena,
      rt:  f('hurto_residencias','tasa_2026_ene_abr'),     rtp: f('hurto_residencias','tasa_2026_proyectada'),
      // violencia intrafamiliar
      vi26: f('violencia_intra','casos_2026_ene_abr'),   vi25: f('violencia_intra','casos_2025_ene_abr'),
      viv:  f('violencia_intra','variacion_pct_ene_abr'), vibp: m.violencia_intra.base_pequena,
      vit:  f('violencia_intra','tasa_2026_ene_abr'),     vitp: f('violencia_intra','tasa_2026_proyectada'),
      // hurto automotores
      a26: f('hurto_automotores','casos_2026_ene_abr'),   a25: f('hurto_automotores','casos_2025_ene_abr'),
      av:  f('hurto_automotores','variacion_pct_ene_abr'), abp: m.hurto_automotores.base_pequena,
      at:  f('hurto_automotores','tasa_2026_ene_abr'),     atp: f('hurto_automotores','tasa_2026_proyectada'),
    };
  });

// Helpers Astro (solo template estático)
function fmtN(n: number | null) { return n !== null && n !== undefined ? n.toLocaleString("es-CO") : null; }
function fmtPct(v: number | null) { if (v === null) return null; return `${v > 0 ? "+" : ""}${v.toFixed(1).replace(".", ",")}%`; }
function varCls(v: number | null) { return v === null ? "neutro" : v > 0 ? "sube" : v < 0 ? "baja" : "neutro"; }
function varArrow(v: number | null) { return v === null ? "" : v > 0 ? "↑ " : v < 0 ? "↓ " : "→ "; }
---

<Layout
  title="Gato en Cifras"
  description="Dashboard de seguridad ciudadana en Colombia: seis delitos de impacto en 38 municipios, tasas x100.000 hab., datos Policía Nacional verificados."
>
  <Fragment slot="head">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css" />
  </Fragment>

  <!-- ═══ HERO ═══════════════════════════════════════════════════════════════ -->
  <section class="cifras-hero">
    <div class="wrap cifras-hero__inner">
      <p class="cifras-hero__kicker">Dashboard de seguridad · Colombia</p>
      <h1 class="cifras-hero__title">Gato en Cifras</h1>
      <p class="cifras-hero__sub">
        Seis delitos de impacto en {totalMunic} municipios —
        homicidios, hurto, extorsión, violencia intrafamiliar y más.
        Tasas x100.000 hab., datos oficiales Policía Nacional verificados.
      </p>
      <div class="cifras-kpis">
        <div class="cifras-kpi">
          <span class="cifras-kpi__num">{homNac26ea.toLocaleString("es-CO")}</span>
          <span class="cifras-kpi__label">homicidios · 38 municipios</span>
          <span class="cifras-kpi__sub">{homNacVar !== null ? (homNacVar > 0 ? "+" : "") + homNacVar.toFixed(1).replace(".", ",") + "%" : "—"} vs. ene-abr 2025 · Policía</span>
        </div>
        <div class="cifras-kpi">
          <span class="cifras-kpi__num">{vifNac26ea.toLocaleString("es-CO")}</span>
          <span class="cifras-kpi__label">casos violencia intrafamiliar</span>
          <span class="cifras-kpi__sub">{vifNacVar !== null ? (vifNacVar > 0 ? "+" : "") + vifNacVar.toFixed(1).replace(".", ",") + "%" : "—"} vs. ene-abr 2025 · Policía</span>
        </div>
        <div class="cifras-kpi">
          <span class="cifras-kpi__num">{topTasa?.homicidio.tasa_2026_proyectada?.toFixed(0)} x100k</span>
          <span class="cifras-kpi__label">{topTasa?.municipio}</span>
          <span class="cifras-kpi__sub">mayor tasa proyectada homicidio 2026 · Policía</span>
        </div>
        <div class="cifras-kpi">
          <span class="cifras-kpi__num">{totalMunic}</span>
          <span class="cifras-kpi__label">ciudades medidas</span>
          <span class="cifras-kpi__sub">38 municipios · 6 delitos de impacto</span>
        </div>
      </div>
      <div class="cifras-corte">
        <span>Datos Policía al <strong>{cortePolicia}</strong></span>
        <span class="cifras-corte__sep">·</span>
        <span>Actualizado <strong>{generadoStr}</strong></span>
      </div>
    </div>
  </section>

  <!-- ═══ AVISO ════════════════════════════════════════════════════════════ -->
  <section class="section wrap">
    <div class="cifras-aviso">
      <p>
        <strong>Cifras sujetas a variación.</strong> Policía Nacional (SIEDCO) se actualiza el día 16
        de cada mes. Series comparables desde 2019. Rankings y mapa siempre por
        <strong>tasa x100.000 hab.</strong>, nunca por absoluto.
      </p>
    </div>
  </section>

  <!-- ═══ ANCLAS ══════════════════════════════════════════════════════════ -->
  <nav class="cifras-anclas wrap" aria-label="Secciones de Gato en Cifras">
    <span class="cifras-anclas__label">Ir a</span>
    <a class="cifras-ancla" href="#indicadores">Indicadores</a>
    <a class="cifras-ancla" href="#mapa">Mapa</a>
    <a class="cifras-ancla" href="#ranking">Ranking</a>
    <a class="cifras-ancla" href="#metodologia-cifras">Fuentes</a>
  </nav>

  <!-- ═══ INDICADORES ══════════════════════════════════════════════════════ -->
  <section class="section wrap" id="indicadores">
    <h2 class="section__title">Indicadores por ciudad</h2>
    <p class="section__byline">ene-abr 2026 vs. ene-abr 2025</p>

    <div class="cifras-ind-bloque">
      <p class="cifras-ind-bloque__label">Resumen · {totalMunic} municipios · Policía Nacional</p>
      <div class="cifras-ind-cards">
        <div class="cifras-ind-card">
          <span class="cifras-ind-card__tipo">Homicidios</span>
          <span class="cifras-ind-card__num">{fmtN(homNac26ea)}</span>
          <span class={`cifras-ind-card__var ${varCls(homNacVar)}`}>{varArrow(homNacVar)}{fmtPct(homNacVar) ?? "—"}</span>
          <span class="cifras-ind-card__tasa">vs. {fmtN(homNac25ea)} en ene-abr 2025</span>
          <div class="cifras-ind-card__footer"><span>38 municipios</span><span>Policía</span></div>
        </div>
        <div class="cifras-ind-card">
          <span class="cifras-ind-card__tipo">Hurto a personas</span>
          <span class="cifras-ind-card__num">{fmtN(hurNac26ea)}</span>
          <span class={`cifras-ind-card__var ${varCls(hurNacVar)}`}>{varArrow(hurNacVar)}{fmtPct(hurNacVar) ?? "—"}</span>
          <span class="cifras-ind-card__tasa">vs. {fmtN(hurNac25ea)} en ene-abr 2025</span>
          <div class="cifras-ind-card__footer"><span>38 municipios</span><span>Policía</span></div>
        </div>
        <div class="cifras-ind-card">
          <span class="cifras-ind-card__tipo">Extorsión</span>
          <span class="cifras-ind-card__num">{fmtN(extNac26ea)}</span>
          <span class={`cifras-ind-card__var ${varCls(extNacVar)}`}>{varArrow(extNacVar)}{fmtPct(extNacVar) ?? "—"}</span>
          <span class="cifras-ind-card__tasa">vs. {fmtN(extNac25ea)} en ene-abr 2025</span>
          <div class="cifras-ind-card__footer"><span>38 municipios</span><span>Policía</span></div>
        </div>
        <div class="cifras-ind-card">
          <span class="cifras-ind-card__tipo">Hurto a residencias</span>
          <span class="cifras-ind-card__num">{fmtN(resNac26ea)}</span>
          <span class={`cifras-ind-card__var ${varCls(resNacVar)}`}>{varArrow(resNacVar)}{fmtPct(resNacVar) ?? "—"}</span>
          <span class="cifras-ind-card__tasa">vs. {fmtN(resNac25ea)} en ene-abr 2025</span>
          <div class="cifras-ind-card__footer"><span>38 municipios</span><span>Policía</span></div>
        </div>
        <div class="cifras-ind-card">
          <span class="cifras-ind-card__tipo">Violencia intrafamiliar</span>
          <span class="cifras-ind-card__num">{fmtN(vifNac26ea)}</span>
          <span class={`cifras-ind-card__var ${varCls(vifNacVar)}`}>{varArrow(vifNacVar)}{fmtPct(vifNacVar) ?? "—"}</span>
          <span class="cifras-ind-card__tasa">vs. {fmtN(vifNac25ea)} en ene-abr 2025</span>
          <div class="cifras-ind-card__footer"><span>38 municipios</span><span>Policía</span></div>
        </div>
        <div class="cifras-ind-card">
          <span class="cifras-ind-card__tipo">Hurto automotores</span>
          <span class="cifras-ind-card__num">{fmtN(autNac26ea)}</span>
          <span class={`cifras-ind-card__var ${varCls(autNacVar)}`}>{varArrow(autNacVar)}{fmtPct(autNacVar) ?? "—"}</span>
          <span class="cifras-ind-card__tasa">vs. {fmtN(autNac25ea)} en ene-abr 2025</span>
          <div class="cifras-ind-card__footer"><span>33 municipios</span><span>Policía</span></div>
        </div>
      </div>
    </div>

    <div class="cifras-selector-row">
      <label class="cifras-selector-label" for="ciudad-select">Ver por ciudad</label>
      <select class="cifras-selector" id="ciudad-select">
        {cityData.map((c: any) => <option value={c.div}>{c.municipio}</option>)}
      </select>
    </div>
    <div class="cifras-ind-bloque">
      <p class="cifras-ind-bloque__label" id="ciudad-nombre">—</p>
      <div class="cifras-ind-cards" id="ciudad-cards"></div>
    </div>
  </section>

  <!-- ═══ MAPA + FILTROS DE DELITO ════════════════════════════════════════ -->
  <section class="section wrap" id="mapa">
    <h2 class="section__title">Mapa por tasa x100.000 hab.</h2>
    <p class="section__byline">Gato en Cifras · tasa proyectada ene-abr 2026 × 3</p>

    <div class="cifras-mapa-filtros">
      <span class="cifras-mapa-filtros__label">Delito</span>
      <div class="cifras-mapa-pills" id="delito-pills">
        <button class="cifras-pill active" data-delito="hom">Homicidios</button>
        <button class="cifras-pill" data-delito="hur">Hurto personas</button>
        <button class="cifras-pill" data-delito="ext">Extorsión</button>
        <button class="cifras-pill" data-delito="res">Hurto residencias</button>
        <button class="cifras-pill" data-delito="vif">Violencia intrafamiliar</button>
        <button class="cifras-pill" data-delito="aut">Hurto automotores</button>
      </div>
    </div>

    <div class="cifras-mapa-wrap">
      <div id="cifras-mapa"></div>
    </div>
    <div id="mapa-leyenda" class="cifras-mapa-leyenda"></div>
    <p class="cifras-mapa-nota">
      Mapa de calor por tasa proyectada (casos ene-abr × 3 ÷ pob. 2026 × 100.000).
      Los puntos marcan las 38 ciudades — clic para ver detalle. Sin dato: gris.
      Todas las cifras: Policía Nacional (SIEDCO).
    </p>
  </section>

  <!-- ═══ RANKING ════════════════════════════════════════════════════════ -->
  <section class="section wrap" id="ranking">
    <h2 class="section__title" id="ranking-titulo">Ranking por tasa x100.000 hab.</h2>
    <p class="section__byline">Gato en Cifras · proyección anual ene-abr 2026</p>

    <div class="cifras-ranking-obs" id="ranking-obs"></div>

    <div class="cifras-ranking-header">
      <span>#</span>
      <span>Ciudad</span>
      <span class="rh-barra">Tasa</span>
      <span class="rh-val">x100k</span>
      <span class="rh-casos">Casos&nbsp;ea</span>
    </div>
    <div id="ranking-lista" class="cifras-ranking-lista"></div>

    <p class="cifras-mapa-nota" style="margin-top:1rem">
      Tasa proyectada = casos ene-abr × 3 ÷ pob. 2026 × 100.000 (proyección, no dato anual real).
      ⚠ = base &lt; 20 casos en ene-abr 2025 — variación % suprimida.
      Fuente: Policía Nacional (SIEDCO). Hurto automotores: 33/38 municipios con dato.
    </p>
  </section>

  <!-- ═══ FUENTES Y METODOLOGÍA ═══════════════════════════════════════════ -->
  <section class="section wrap cifras-metodologia" id="metodologia-cifras">
    <h2 class="section__title">Fuentes y metodología</h2>
    <p class="section__byline">Gato en Cifras</p>
    <div class="cifras-fuentes">
      <div class="cifras-fuente">
        <strong>Homicidios — Policía Nacional</strong>
        <span>SIEDCO · datos.gov.co · <code>m8fd-ahd9</code></span>
        <span class="cifras-fuente__nota">Sujeto a variación. Corte: {cortePolicia}.</span>
      </div>
      <div class="cifras-fuente">
        <strong>Hurto a personas — Policía Nacional</strong>
        <span>SIEDCO · datos.gov.co · <code>4rxi-8m8d</code></span>
        <span class="cifras-fuente__nota">Sujeto a variación. Corte: {cortePolicia}.</span>
      </div>
      <div class="cifras-fuente">
        <strong>Extorsión — Policía Nacional</strong>
        <span>SIEDCO · datos.gov.co · <code>q2ib-t9am</code></span>
        <span class="cifras-fuente__nota">Sujeto a variación. Corte: {cortePolicia}.</span>
      </div>
      <div class="cifras-fuente">
        <strong>Hurto a residencias — Policía Nacional</strong>
        <span>SIEDCO · datos.gov.co · <code>7mn7-vzqp</code></span>
        <span class="cifras-fuente__nota">Sujeto a variación. Corte: {cortePolicia}.</span>
      </div>
      <div class="cifras-fuente">
        <strong>Violencia intrafamiliar — Policía Nacional</strong>
        <span>SIEDCO · datos.gov.co · <code>gepp-dxcs</code></span>
        <span class="cifras-fuente__nota">Sujeto a variación. Corte: {cortePolicia}.</span>
      </div>
      <div class="cifras-fuente">
        <strong>Hurto automotores — Policía Nacional</strong>
        <span>SIEDCO · datos.gov.co · <code>csb4-y6v2</code> · tipo_delito = HURTO AUTOMOTORES</span>
        <span class="cifras-fuente__nota">Sujeto a variación. Dato disponible en 33/38 municipios. Corte: {cortePolicia}.</span>
      </div>
      <div class="cifras-fuente">
        <strong>Población</strong>
        <span>DANE · Proyecciones municipales 2018-2042 (CNPV 2018)</span>
        <span class="cifras-fuente__nota">Tasa = (casos ÷ pob. mismo año) × 100.000.</span>
      </div>
    </div>
    <p class="cifras-metodologia__nota">
      Todas las cifras de criminalidad provienen de la <strong>Policía Nacional (SIEDCO)</strong>,
      sistema único de información estadística delictiva. Los datos son sujetos a variación
      posterior por procesos de verificación y ajuste. Series comparables únicamente desde 2019
      (quiebre metodológico SIEDCO-SPOA en 2016-2018). Tasa proyectada = casos ene-abr × 3
      — es una estimación anual, no un dato definitivo.
    </p>
  </section>

<style>
/* ── Anclas ───────────────────────────────────────────────────────────────── */
.cifras-anclas {
  display: flex; align-items: center; gap: 0.5rem 1rem; flex-wrap: wrap;
  padding: 0.65rem 0; border-bottom: 1px solid var(--border);
  font-size: 0.75rem;
}
.cifras-anclas__label {
  font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
  color: var(--ink-soft); margin-right: 0.25rem; white-space: nowrap;
}
.cifras-ancla {
  color: var(--ink-soft); text-decoration: none; padding: 0.2rem 0.55rem;
  border: 1px solid transparent; border-radius: 6px; transition: all 0.15s; white-space: nowrap;
}
.cifras-ancla:hover { border-color: rgba(230,179,0,0.4); color: var(--accent); }

/* ── Hero ─────────────────────────────────────────────────────────────────── */
.cifras-hero {
  background: linear-gradient(180deg, rgba(5,5,8,0) 0%, var(--bg) 100%), var(--surface);
  border-bottom: 1px solid var(--border); padding: 3.5rem 0 2.5rem;
}
.cifras-hero__inner { max-width: 900px; }
.cifras-hero__kicker {
  font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--accent); margin-bottom: 0.5rem;
}
.cifras-hero__title {
  font-family: var(--font-display); font-size: clamp(2.2rem, 5vw, 3.5rem);
  font-weight: 900; line-height: 1.1; color: var(--ink); margin-bottom: 0.75rem;
}
.cifras-hero__sub {
  font-size: 1rem; color: var(--ink-soft); max-width: 680px;
  margin-bottom: 2.5rem; line-height: 1.6;
}
