:global(.leaflet-popup-tip)             { background: #1e2535 !important; }
:global(.leaflet-popup-close-button)    { color: #8892a4 !important; }
:global(.leaflet-control-zoom a)        { background: #1e2535 !important; color: #f0f4f8 !important; border-color: rgba(255,255,255,0.1) !important; }
:global(.leaflet-control-attribution)   { background: rgba(13,17,23,0.75) !important; color: #8892a4 !important; font-size: 0.6rem !important; }
:global(.leaflet-control-attribution a){ color: #e6b300 !important; }
.cifras-mapa-leyenda {
