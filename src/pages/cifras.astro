.cifras-mapa-wrap { border-radius: var(--radius); overflow: hidden; border: 1px solid var(--border); margin-bottom: 0.75rem; }
#cifras-mapa { height: 580px; width: 100%; background: var(--surface-2); }
:global(.leaflet-container)              { background: #1a2030 !important; font-family: var(--font-body) !important; }
