}

/* ── Responsive ───────────────────────────────────────────────────────────── */
@media (max-width: 600px) {
  .cifras-kpis { grid-template-columns: repeat(2, 1fr); }
  .cifras-ind-cards { grid-template-columns: 1fr; }
  #cifras-mapa { height: 380px; }
  .cifras-ranking-header,
  .ranking-row {
    grid-template-columns: 1.8rem 1fr 60px 55px;
  }
  .rh-barra, .rr-barra-wrap { display: none; }
}
</style>

<!-- Leaflet JS ──────────────────────────────────────────────────────────────── -->
<script is:inline src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/leaflet.heat@0.2.0/dist/leaflet-heat.js"></script>

<!-- App ──────────────────────────────────────────────────────────────────────── -->
<script is:inline define:vars={{ cityData }}>
/* ══════════════ HELPERS ════════════════════════════════════════════════════ */
function numCO(n) { return (n !== null && n !== undefined) ? n.toLocaleString("es-CO") : null; }
function tasaStr(t) { return (t !== null && t !== undefined) ? t.toFixed(1).replace(".", ",") + " x100k" : null; }
function varHtml(v, bp) {
  if (bp) return '<span class="cifras-ind-card__var base-p">⚠ base &lt; 20 casos — variación no significativa</span>';
  if (v === null || v === undefined) return '<span class="cifras-ind-card__var neutro">—</span>';
  const s = v > 0 ? "+" : "", a = v > 0 ? "↑ " : v < 0 ? "↓ " : "→ ";
  const c = v > 0 ? "sube" : v < 0 ? "baja" : "neutro";
  return `<span class="cifras-ind-card__var ${c}">${a}${s}${v.toFixed(1).replace(".",",")}%</span>`;
}

/* ══════════════ SELECTORES DE DELITO (6) ═══════════════════════════════════ */
function getTasa(c, d) {
  return d==='hom'?c.htp : d==='hur'?c.utp : d==='ext'?c.etp :
         d==='res'?c.rtp : d==='vif'?c.vitp : c.atp;
}
function getCasos(c, d) {
  return d==='hom'?c.h26 : d==='hur'?c.u26 : d==='ext'?c.e26 :
         d==='res'?c.r26 : d==='vif'?c.vi26 : c.a26;
}
function getBP(c, d) {
  return d==='hom'?c.hbp : d==='hur'?c.ubp : d==='ext'?c.ebp :
         d==='res'?c.rbp : d==='vif'?c.vibp : c.abp;
}
function getLabel(d) {
  return d==='hom'?'Homicidios' : d==='hur'?'Hurto a personas' : d==='ext'?'Extorsión' :
         d==='res'?'Hurto residencias' : d==='vif'?'Violencia intrafamiliar' : 'Hurto automotores';
}

/* ══════════════ ESCALA DE COLOR ════════════════════════════════════════════ */
const PAL = ["#f0d9a8","#e0a96a","#cc7840","#b54e2e","#8a2018"];
const SIN_COLOR = "#3a4050";

function quintiles(vals) {
  const s = [...vals].filter(v => v != null).sort((a,b) => a - b);
  if (!s.length) return [0,10,20,40,60,100];
  const q = i => s[Math.floor((i/5)*s.length)] ?? s[s.length-1];
  return [s[0], q(1), q(2), q(3), q(4), s[s.length-1]];
}
function palColor(t, brks) {
  if (t == null) return SIN_COLOR;
  for (let i = 0; i < PAL.length; i++) if (t <= brks[i+1]) return PAL[i];
  return PAL[PAL.length-1];
}

/* ══════════════ SELECTOR DE CIUDAD ════════════════════════════════════════ */
function kpiCard(tipo, n26, n25, vari, bp, tasa) {
  const ant = numCO(n25);
  const ts  = tasaStr(tasa);
  const nl  = n26 != null ? numCO(n26) : '<span class="sin-dato">sin dato</span>';
  const tl  = ts ? `${ts} · vs. ${ant ?? "—"} ene-abr 2025` : `vs. ${ant ?? "—"} ene-abr 2025`;
  return `<div class="cifras-ind-card">
    <span class="cifras-ind-card__tipo">${tipo}</span>
    <span class="cifras-ind-card__num">${nl}</span>
    ${varHtml(vari, bp)}
    <span class="cifras-ind-card__tasa">${tl}</span>
    <div class="cifras-ind-card__footer"><span>ene-abr 2026</span><span>Policía</span></div>
  </div>`;
}
function renderCity(c) {
  document.getElementById("ciudad-nombre").textContent = c.municipio;
  document.getElementById("ciudad-cards").innerHTML = [
    kpiCard("Homicidios",              c.h26,  c.h25,  c.hv,  c.hbp,  c.ht),
    kpiCard("Hurto a personas",        c.u26,  c.u25,  c.uv,  c.ubp,  c.ut),
    kpiCard("Extorsión",               c.e26,  c.e25,  c.ev,  c.ebp,  c.et),
    kpiCard("Hurto a residencias",     c.r26,  c.r25,  c.rv,  c.rbp,  c.rt),
    kpiCard("Violencia intrafamiliar", c.vi26, c.vi25, c.viv, c.vibp, c.vit),
    kpiCard("Hurto automotores",       c.a26,  c.a25,  c.av,  c.abp,  c.at),
  ].join("");
}
const sel = document.getElementById("ciudad-select");
const def = cityData.find(c => c.div === "11001") ?? cityData[0];
if (def) { sel.value = def.div; renderCity(def); }
sel.addEventListener("change", () => {
  const c = cityData.find(c => c.div === sel.value);
  if (c) renderCity(c);
});

/* ══════════════ MAPA ═══════════════════════════════════════════════════════ */
if (typeof L === 'undefined') {
  document.getElementById('cifras-mapa').innerHTML =
    '<p style="display:flex;align-items:center;justify-content:center;height:100%;color:#8892a4;font-size:.85rem">El mapa no pudo cargar — verifica tu conexión y recarga la página.</p>';
}
const map = typeof L !== 'undefined' && L.map("cifras-mapa", {
  center: [4.5, -74.5], zoom: 5, scrollWheelZoom: false,
  zoomControl: true,
});
if (map) {
  L.tileLayer("https://{s}.basemaps.cartocdn.com/dark_nolabels/{z}/{x}/{y}{r}.png", {
    attribution: '© <a href="https://carto.com/">CartoDB</a> · © <a href="https://osm.org/copyright">OSM</a>',
    maxZoom: 14,
  }).addTo(map);
}
const mLayer = map ? L.layerGroup().addTo(map) : null;
let heatLayer = null;

// Control "Ver todas las ciudades"
if (map) {
  const FitControl = L.Control.extend({
    options: { position: 'topright' },
    onAdd() {
      const btn = L.DomUtil.create('button', '');
      btn.innerHTML = '⊞ Ver todas las ciudades';
      btn.style.cssText = 'background:rgba(26,32,48,.92);color:#e6b300;border:1px solid rgba(230,179,0,.4);border-radius:6px;padding:6px 11px;font-size:.7rem;font-weight:700;cursor:pointer;font-family:inherit;letter-spacing:.04em;white-space:nowrap;box-shadow:0 2px 6px rgba(0,0,0,.4);';
      L.DomEvent.on(btn, 'click', function(e) {
        L.DomEvent.stopPropagation(e);
        L.DomEvent.preventDefault(e);
        const pts = cityData.filter(c => c.lat != null).map(c => [c.lat, c.lng]);
        if (pts.length) map.fitBounds(L.latLngBounds(pts), { padding: [50, 50] });
      });
      return btn;
    }
  });
  new FitControl().addTo(map);
}

function renderMapa(d) {
  if (!map) return;

  // Limpiar capas anteriores
  if (mLayer) mLayer.clearLayers();
  if (heatLayer) { map.removeLayer(heatLayer); heatLayer = null; }

  const brks = quintiles(cityData.map(c => getTasa(c, d)));
  const maxT = cityData.reduce((m, c) => Math.max(m, getTasa(c, d) ?? 0), 0) || 1;

  // ── Capa de calor ──────────────────────────────────────────────────────
  if (typeof L.heatLayer !== 'undefined') {
    const heatData = cityData
      .filter(c => c.lat != null && getTasa(c, d) != null)
      .map(c => [c.lat, c.lng, getTasa(c, d) / maxT]);
    if (heatData.length) {
      heatLayer = L.heatLayer(heatData, {
        radius: 70,
        blur: 55,
        maxZoom: 10,
        gradient: { 0: 'rgba(0,0,0,0)', 0.2: '#f0d9a8', 0.5: '#cc7840', 0.75: '#b54e2e', 1: '#8a2018' },
      }).addTo(map);
    }
  }

  // ── Marcadores de ciudad (clickables) ──────────────────────────────────
  cityData.forEach(c => {
    if (c.lat == null) return;
    const t  = getTasa(c, d);
    const cc = getCasos(c, d);
    const col = palColor(t, brks);
    L.circleMarker([c.lat, c.lng], {
      radius: t != null ? 7 : 5,
      fillColor: col,
      color: t != null ? 'rgba(255,255,255,0.5)' : 'rgba(255,255,255,0.15)',
      weight: 1.5,
      fillOpacity: t != null ? 0.95 : 0.4,
    }).bindPopup(`
      <div style="min-width:185px;line-height:1.6">
        <strong style="font-size:.96rem">${c.municipio}</strong><br>
        <span style="font-size:.68rem;color:#8892a4;text-transform:uppercase;letter-spacing:.06em">${getLabel(d)}</span><br>
        <hr style="border:none;border-top:1px solid rgba(255,255,255,.1);margin:5px 0">
        <span style="font-size:.84rem">Casos ene-abr 2026: <strong>${cc != null ? numCO(cc) : "sin dato"}</strong></span><br>
        <span style="font-size:.84rem">Tasa proyectada: ${t != null ? "<strong>" + t.toFixed(1).replace(".",",") + " x100k</strong>" : "sin dato"}</span><br>
        <span style="font-size:.65rem;color:#8892a4;margin-top:4px;display:block">Policía Nacional · ene-abr 2026</span>
      </div>`, { maxWidth: 240 }).addTo(mLayer);
  });

  // ── Leyenda ────────────────────────────────────────────────────────────
  const items = PAL.map((col, i) => {
    const lo = i === 0 ? "0" : brks[i].toFixed(0);
    const hi = i === PAL.length-1 ? brks[i+1].toFixed(0)+"+" : brks[i+1].toFixed(0);
    return `<div class="cifras-mapa-leyenda-item"><div class="cifras-mapa-leyenda-dot" style="background:${col}"></div><span>${lo}–${hi}</span></div>`;
  }).join("") + `<div class="cifras-mapa-leyenda-item"><div class="cifras-mapa-leyenda-dot" style="background:${SIN_COLOR}"></div><span>sin dato</span></div>`;
  document.getElementById("mapa-leyenda").innerHTML =
    `<span style="font-size:.67rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;margin-right:.25rem">Tasa x100k</span>` + items;
}

/* ══════════════ RANKING ════════════════════════════════════════════════════ */
function renderRanking(d) {
  const brks    = quintiles(cityData.map(c => getTasa(c, d)));
  const sorted  = [...cityData].sort((a, b) => {
    const ta = getTasa(a, d) ?? -1, tb = getTasa(b, d) ?? -1;
    return tb - ta;
  });
  const conDato = sorted.filter(c => getTasa(c, d) != null);
  const sinDato = sorted.filter(c => getTasa(c, d) == null);
  const maxTasa = conDato.length ? getTasa(conDato[0], d) : 1;

  const maxAbsCity = [...cityData].sort((a, b) => (getCasos(b,d) ?? 0) - (getCasos(a,d) ?? 0))[0];
  const maxAbsRank = conDato.findIndex(c => c.div === maxAbsCity?.div) + 1;
  const topCity    = conDato[0];

  document.getElementById("ranking-titulo").textContent =
    `${getLabel(d)} — ranking por tasa x100.000 hab.`;

  let obs = "";
  if (topCity && maxAbsCity && topCity.div !== maxAbsCity.div) {
    const topT = getTasa(topCity, d)?.toFixed(1).replace(".", ",");
    const macC = numCO(getCasos(maxAbsCity, d));
    obs = `<strong>${topCity.municipio}</strong> lidera en tasa (${topT} x100k proyectado).
      <strong>${maxAbsCity.municipio}</strong>, con más casos en absoluto (${macC}),
      ocupa el puesto <strong>${maxAbsRank}</strong> en tasa —
      el tamaño de una ciudad no define su nivel de violencia por habitante.`;
  } else if (topCity) {
    const topT = getTasa(topCity, d)?.toFixed(1).replace(".", ",");
    obs = `<strong>${topCity.municipio}</strong> lidera tanto en tasa (${topT} x100k) como en casos absolutos para ${getLabel(d).toLowerCase()}.`;
  }
  document.getElementById("ranking-obs").innerHTML = obs;

  function row(c, pos) {
    const t    = getTasa(c, d);
    const cc   = getCasos(c, d);
    const bp   = getBP(c, d);
    const isAbsTop = c.div === maxAbsCity?.div;
    if (t == null) {
      return `<div class="ranking-row ranking-row--sin-dato">
        <span class="rr-pos">${pos}</span>
        <span class="rr-nombre">${c.municipio}</span>
        <div class="rr-barra-wrap"></div>
        <span class="rr-tasa sin-dato">sin dato</span>
        <span class="rr-casos">${cc != null ? numCO(cc) : "—"}</span>
      </div>`;
    }
    const bw  = maxTasa > 0 ? (t / maxTasa * 100).toFixed(1) : 0;
    const col = palColor(t, brks);
    const tStr = t.toFixed(1).replace(".", ",");
    const absTag = isAbsTop ? ` <span class="rr-tag rr-tag--abs">↑ casos abs.</span>` : "";
    const warn   = bp ? ` <span class="rr-warn" title="Base &lt; 20 casos en 2025">⚠</span>` : "";
    return `<div class="ranking-row">
      <span class="rr-pos${pos <= 5 ? " rr-pos--dest" : ""}">${pos}</span>
      <span class="rr-nombre">${c.municipio}${absTag}${warn}</span>
      <div class="rr-barra-wrap"><div class="rr-barra" style="width:${bw}%;background:${col}"></div></div>
      <span class="rr-tasa">${tStr}</span>
      <span class="rr-casos">${cc != null ? numCO(cc) : "—"}</span>
    </div>`;
  }

  const rowsHTML = conDato.map((c, i) => row(c, i + 1)).join("");
  const sepHTML  = sinDato.length
    ? `<div class="ranking-sep">Sin dato suficiente (${sinDato.length} ciudad${sinDato.length > 1 ? "es" : ""})</div>`
      + sinDato.map((c, i) => row(c, conDato.length + i + 1)).join("")
    : "";
  document.getElementById("ranking-lista").innerHTML = rowsHTML + sepHTML;
}

/* ══════════════ ESTADO COMPARTIDO Y FILTROS ════════════════════════════════ */
let activeDelito = "hom";

function updateAll(d) {
  renderMapa(d);
  renderRanking(d);
}

updateAll(activeDelito);

document.querySelectorAll("[data-delito]").forEach(btn => {
  btn.addEventListener("click", () => {
    document.querySelectorAll("[data-delito]").forEach(b => b.classList.remove("active"));
    btn.classList.add("active");
    activeDelito = btn.dataset.delito;
    updateAll(activeDelito);
  });
});
</script>

</Layout>
