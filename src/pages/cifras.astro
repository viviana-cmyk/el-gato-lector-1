---
import Layout from "../layouts/Layout.astro";
import cifrasData from "../data/cifras.data.json";

const data = cifrasData as any;
const meta = data.meta;

// Fechas
const cortePolicia = new Date(meta.corte_policia + 'T00:00:00-05:00')
  .toLocaleDateString("es-CO", { day: "numeric", month: "long", year: "numeric", timeZone: "America/Bogota" });
const generadoStr = new Date(meta.generatedAt)
  .toLocaleDateString("es-CO", { day: "numeric", month: "long", year: "numeric", timeZone: "America/Bogota" });

// Helpers para totales
const totalMunic = data.municipios.length;
const sum25 = (campo: string) => (data.municipios as any[]).reduce((s: number, m: any) => s + (m[campo].casos_2025_ene_abr ?? 0), 0);
const sum26 = (campo: string) => (data.municipios as any[]).reduce((s: number, m: any) => s + (m[campo].casos_2026_ene_abr ?? 0), 0);
const nacVar = (campo: string) => {
  const a = sum25(campo), b = sum26(campo);
  return a > 0 ? Math.round(((b - a) / a) * 1000) / 10 : null;
};

// Hero
const topTasa = [...data.municipios]
  .filter((m: any) => m.homicidio.tasa_2026_proyectada)
  .sort((a: any, b: any) => b.homicidio.tasa_2026_proyectada - a.homicidio.tasa_2026_proyectada)[0];

// Nacionales — 6 delitos
const homNac25ea = sum25('homicidio'),   homNac26ea = sum26('homicidio'),   homNacVar = nacVar('homicidio');
const hurNac25ea = sum25('hurto_personas'), hurNac26ea = sum26('hurto_personas'), hurNacVar = nacVar('hurto_personas');
const extNac25ea = sum25('extorsion'),   extNac26ea = sum26('extorsion'),   extNacVar = nacVar('extorsion');
const resNac25ea = sum25('hurto_residencias'), resNac26ea = sum26('hurto_residencias'), resNacVar = nacVar('hurto_residencias');
const vifNac25ea = sum25('violencia_intra'),   vifNac26ea = sum26('violencia_intra'),   vifNacVar = nacVar('violencia_intra');
const autNac25ea = sum25('hurto_automotores'), autNac26ea = sum26('hurto_automotores'), autNacVar = nacVar('hurto_automotores');

// Coordenadas de los 38 municipios
const COORDS: Record<string, [number, number]> = {
  "11001": [4.7110, -74.0721],   "05001": [6.2518, -75.5636],
  "76001": [3.4516, -76.5320],   "08001": [10.9685, -74.7813],
  "13001": [10.3997, -75.5144],  "54001": [7.8939, -72.5078],
  "68001": [7.1254, -73.1198],   "73001": [4.4389, -75.2322],
  "50001": [4.1420, -73.6266],   "47001": [11.2408, -74.1990],
  "66001": [4.8133, -75.6961],   "20001": [10.4631, -73.2532],
  "23001": [8.7575, -75.8831],   "52001": [1.2136, -77.2811],
  "17001": [5.0689, -75.5174],   "41001": [2.9273, -75.2820],
  "63001": [4.5339, -75.6811],   "19001": [2.4448, -76.6147],
  "70001": [9.3047, -75.3978],   "44001": [11.5444, -72.9072],
  "27001": [5.6919, -76.6583],   "15001": [5.5353, -73.3678],
  "18001": [1.6144, -75.6062],   "85001": [5.3378, -72.3956],
  "81001": [7.0846, -70.7583],   "86001": [1.1522, -76.6498],
  "88001": [12.5847, -81.7006],  "91001": [-4.2153, -69.9408],
  "94001": [3.8653, -67.9239],   "95001": [2.5637, -72.6399],
  "97001": [1.1983, -70.1742],   "99001": [6.1891, -67.4844],
  "25754": [4.5793, -74.2169],   "08758": [10.9183, -74.7669],
  "05088": [6.3292, -75.5576],   "76520": [3.5394, -76.3033],
  "05360": [6.1843, -75.5985],   "68276": [7.0636, -73.0937],
};

// cityData compacto — 6 delitos, todos Policía
const cityData = [...data.municipios]
  .sort((a: any, b: any) => a.municipio.localeCompare(b.municipio, "es"))
  .map((m: any) => {
    const coord = COORDS[m.divipola] ?? null;
    const f = (campo: string, k: string) => m[campo][k] ?? null;
    return {
      municipio: m.municipio,
      div: m.divipola,
      lat: coord?.[0] ?? null,
      lng: coord?.[1] ?? null,
      // homicidio
      h26: f('homicidio','casos_2026_ene_abr'),   h25: f('homicidio','casos_2025_ene_abr'),
      hv:  f('homicidio','variacion_pct_ene_abr'), hbp: m.homicidio.base_pequena,
      ht:  f('homicidio','tasa_2026_ene_abr'),     htp: f('homicidio','tasa_2026_proyectada'),
      // hurto personas
      u26: f('hurto_personas','casos_2026_ene_abr'),   u25: f('hurto_personas','casos_2025_ene_abr'),
      uv:  f('hurto_personas','variacion_pct_ene_abr'), ubp: m.hurto_personas.base_pequena,
      ut:  f('hurto_personas','tasa_2026_ene_abr'),     utp: f('hurto_personas','tasa_2026_proyectada'),
      // extorsión
      e26: f('extorsion','casos_2026_ene_abr'),   e25: f('extorsion','casos_2025_ene_abr'),
      ev:  f('extorsion','variacion_pct_ene_abr'), ebp: m.extorsion.base_pequena,
      et:  f('extorsion','tasa_2026_ene_abr'),     etp: f('extorsion','tasa_2026_proyectada'),
      // hurto residencias
      r26: f('hurto_residencias','casos_2026_ene_abr'),   r25: f('hurto_residencias','casos_2025_ene_abr'),
      rv:  f('hurto_residencias','variacion_pct_ene_abr'), rbp: m.hurto_residencias.base_pequena,
      rt:  f('hurto_residencias','tasa_2026_ene_abr'),     rtp: f('hurto_residencias','tasa_2026_proyectada'),
      // violencia intrafamiliar
      vi26: f('violencia_intra','casos_2026_ene_abr'),   vi25: f('violencia_intra','casos_2025_ene_abr'),
      viv:  f('violencia_intra','variacion_pct_ene_abr'), vibp: m.violencia_intra.base_pequena,
      vit:  f('violencia_intra','tasa_2026_ene_abr'),     vitp: f('violencia_intra','tasa_2026_proyectada'),
      // hurto automotores
      a26: f('hurto_automotores','casos_2026_ene_abr'),   a25: f('hurto_automotores','casos_2025_ene_abr'),
      av:  f('hurto_automotores','variacion_pct_ene_abr'), abp: m.hurto_automotores.base_pequena,
      at:  f('hurto_automotores','tasa_2026_ene_abr'),     atp: f('hurto_automotores','tasa_2026_proyectada'),
    };
  });

// Helpers Astro (solo template estático)
function fmtN(n: number | null) { return n !== null && n !== undefined ? n.toLocaleString("es-CO") : null; }
function fmtPct(v: number | null) { if (v === null) return null; return `${v > 0 ? "+" : ""}${v.toFixed(1).replace(".", ",")}%`; }
function varCls(v: number | null) { return v === null ? "neutro" : v > 0 ? "sube" : v < 0 ? "baja" : "neutro"; }
function varArrow(v: number | null) { return v === null ? "" : v > 0 ? "↑ " : v < 0 ? "↓ " : "→ "; }
---

<Layout
  title="Gato en Cifras"
  description="Dashboard de seguridad ciudadana en Colombia: seis delitos de impacto en 38 municipios, tasas x100.000 hab., datos Policía Nacional verificados."
>
  <Fragment slot="head">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css" />
  </Fragment>

  <!-- ═══ HERO ═══════════════════════════════════════════════════════════════ -->
  <section class="cifras-hero">
    <div class="wrap cifras-hero__inner">
      <p class="cifras-hero__kicker">Dashboard de seguridad · Colombia</p>
      <h1 class="cifras-hero__title">Gato en Cifras</h1>
      <p class="cifras-hero__sub">
        Seis delitos de impacto en {totalMunic} municipios —
        homicidios, hurto, extorsión, violencia intrafamiliar y más.
        Tasas x100.000 hab., datos oficiales Policía Nacional verificados.
      </p>
      <div class="cifras-kpis">
        <div class="cifras-kpi">
          <span class="cifras-kpi__num">{homNac26ea.toLocaleString("es-CO")}</span>
          <span class="cifras-kpi__label">homicidios · 38 municipios</span>
          <span class="cifras-kpi__sub">{homNacVar !== null ? (homNacVar > 0 ? "+" : "") + homNacVar.toFixed(1).replace(".", ",") + "%" : "—"} vs. ene-abr 2025 · Policía</span>
        </div>
        <div class="cifras-kpi">
          <span class="cifras-kpi__num">{vifNac26ea.toLocaleString("es-CO")}</span>
          <span class="cifras-kpi__label">casos violencia intrafamiliar</span>
          <span class="cifras-kpi__sub">{vifNacVar !== null ? (vifNacVar > 0 ? "+" : "") + vifNacVar.toFixed(1).replace(".", ",") + "%" : "—"} vs. ene-abr 2025 · Policía</span>
        </div>
        <div class="cifras-kpi">
          <span class="cifras-kpi__num">{topTasa?.homicidio.tasa_2026_proyectada?.toFixed(0)} x100k</span>
          <span class="cifras-kpi__label">{topTasa?.municipio}</span>
          <span class="cifras-kpi__sub">mayor tasa proyectada homicidio 2026 · Policía</span>
        </div>
        <div class="cifras-kpi">
          <span class="cifras-kpi__num">{totalMunic}</span>
          <span class="cifras-kpi__label">ciudades medidas</span>
          <span class="cifras-kpi__sub">38 municipios · 6 delitos de impacto</span>
        </div>
      </div>
      <div class="cifras-corte">
        <span>Datos Policía al <strong>{cortePolicia}</strong></span>
        <span class="cifras-corte__sep">·</span>
        <span>Actualizado <strong>{generadoStr}</strong></span>
      </div>
    </div>
  </section>

  <!-- ═══ AVISO ════════════════════════════════════════════════════════════ -->
  <section class="section wrap">
    <div class="cifras-aviso">
      <p>
        <strong>Cifras sujetas a variación.</strong> Policía Nacional (SIEDCO) se actualiza el día 16
        de cada mes. Series comparables desde 2019. Rankings y mapa siempre por
        <strong>tasa x100.000 hab.</strong>, nunca por absoluto.
      </p>
    </div>
  </section>

  <!-- ═══ ANCLAS ══════════════════════════════════════════════════════════ -->
  <nav class="cifras-anclas wrap" aria-label="Secciones de Gato en Cifras">
    <span class="cifras-anclas__label">Ir a</span>
    <a class="cifras-ancla" href="#indicadores">Indicadores</a>
    <a class="cifras-ancla" href="#mapa">Mapa</a>
    <a class="cifras-ancla" href="#ranking">Top 5</a>
  </nav>

  <!-- ═══ INDICADORES ══════════════════════════════════════════════════════ -->
  <section class="section wrap" id="indicadores">
    <h2 class="section__title">Indicadores por ciudad</h2>
    <p class="section__byline">ene-abr 2026 vs. ene-abr 2025</p>

    <div class="cifras-ind-bloque">
      <p class="cifras-ind-bloque__label">Resumen · {totalMunic} municipios · Policía Nacional</p>
      <div class="cifras-ind-cards">
        <div class="cifras-ind-card">
          <span class="cifras-ind-card__tipo">Homicidios</span>
          <span class="cifras-ind-card__num">{fmtN(homNac26ea)}</span>
          <span class={`cifras-ind-card__var ${varCls(homNacVar)}`}>{varArrow(homNacVar)}{fmtPct(homNacVar) ?? "—"}</span>
          <span class="cifras-ind-card__tasa">vs. {fmtN(homNac25ea)} en ene-abr 2025</span>
          <div class="cifras-ind-card__footer"><span>38 municipios</span><span>Policía</span></div>
        </div>
        <div class="cifras-ind-card">
          <span class="cifras-ind-card__tipo">Hurto a personas</span>
          <span class="cifras-ind-card__num">{fmtN(hurNac26ea)}</span>
          <span class={`cifras-ind-card__var ${varCls(hurNacVar)}`}>{varArrow(hurNacVar)}{fmtPct(hurNacVar) ?? "—"}</span>
          <span class="cifras-ind-card__tasa">vs. {fmtN(hurNac25ea)} en ene-abr 2025</span>
          <div class="cifras-ind-card__footer"><span>38 municipios</span><span>Policía</span></div>
        </div>
        <div class="cifras-ind-card">
          <span class="cifras-ind-card__tipo">Extorsión</span>
          <span class="cifras-ind-card__num">{fmtN(extNac26ea)}</span>
          <span class={`cifras-ind-card__var ${varCls(extNacVar)}`}>{varArrow(extNacVar)}{fmtPct(extNacVar) ?? "—"}</span>
          <span class="cifras-ind-card__tasa">vs. {fmtN(extNac25ea)} en ene-abr 2025</span>
          <div class="cifras-ind-card__footer"><span>38 municipios</span><span>Policía</span></div>
        </div>
        <div class="cifras-ind-card">
          <span class="cifras-ind-card__tipo">Hurto a residencias</span>
          <span class="cifras-ind-card__num">{fmtN(resNac26ea)}</span>
          <span class={`cifras-ind-card__var ${varCls(resNacVar)}`}>{varArrow(resNacVar)}{fmtPct(resNacVar) ?? "—"}</span>
          <span class="cifras-ind-card__tasa">vs. {fmtN(resNac25ea)} en ene-abr 2025</span>
          <div class="cifras-ind-card__footer"><span>38 municipios</span><span>Policía</span></div>
        </div>
        <div class="cifras-ind-card">
          <span class="cifras-ind-card__tipo">Violencia intrafamiliar</span>
          <span class="cifras-ind-card__num">{fmtN(vifNac26ea)}</span>
          <span class={`cifras-ind-card__var ${varCls(vifNacVar)}`}>{varArrow(vifNacVar)}{fmtPct(vifNacVar) ?? "—"}</span>
          <span class="cifras-ind-card__tasa">vs. {fmtN(vifNac25ea)} en ene-abr 2025</span>
          <div class="cifras-ind-card__footer"><span>38 municipios</span><span>Policía</span></div>
        </div>
        <div class="cifras-ind-card">
          <span class="cifras-ind-card__tipo">Hurto automotores</span>
          <span class="cifras-ind-card__num">{fmtN(autNac26ea)}</span>
          <span class={`cifras-ind-card__var ${varCls(autNacVar)}`}>{varArrow(autNacVar)}{fmtPct(autNacVar) ?? "—"}</span>
          <span class="cifras-ind-card__tasa">vs. {fmtN(autNac25ea)} en ene-abr 2025</span>
          <div class="cifras-ind-card__footer"><span>33 municipios</span><span>Policía</span></div>
        </div>
      </div>
    </div>

    <div class="cifras-selector-row">
      <label class="cifras-selector-label" for="ciudad-select">Ver por ciudad</label>
      <select class="cifras-selector" id="ciudad-select">
        {cityData.map((c: any) => <option value={c.div}>{c.municipio}</option>)}
      </select>
    </div>
    <div class="cifras-ciudad-bloque">
      <p class="cifras-ciudad-nombre" id="ciudad-nombre">—</p>
      <div class="cifras-ciudad-cards" id="ciudad-cards"></div>
    </div>
  </section>

  <!-- ═══ MAPA + FILTROS DE DELITO ════════════════════════════════════════ -->
  <section class="section wrap" id="mapa">
    <h2 class="section__title">Mapa por tasa x100.000 hab.</h2>
    <p class="section__byline">Gato en Cifras · tasa proyectada ene-abr 2026 × 3</p>

    <div class="cifras-mapa-filtros">
      <span class="cifras-mapa-filtros__label">Delito</span>
      <div class="cifras-mapa-pills" id="delito-pills">
        <button class="cifras-pill active" data-delito="hom">Homicidios</button>
        <button class="cifras-pill" data-delito="hur">Hurto personas</button>
        <button class="cifras-pill" data-delito="ext">Extorsión</button>
        <button class="cifras-pill" data-delito="res">Hurto residencias</button>
        <button class="cifras-pill" data-delito="vif">Violencia intrafamiliar</button>
        <button class="cifras-pill" data-delito="aut">Hurto automotores</button>
      </div>
    </div>

    <div class="cifras-mapa-wrap">
      <div id="cifras-mapa"></div>
    </div>
    <div id="mapa-leyenda" class="cifras-mapa-leyenda"></div>
    <p class="cifras-mapa-nota">
      Mapa de calor por tasa proyectada (casos ene-abr × 3 ÷ pob. 2026 × 100.000).
      Los puntos marcan las 38 ciudades — clic para ver detalle. Sin dato: gris.
      Todas las cifras: Policía Nacional (SIEDCO).
    </p>
  </section>

  <!-- ═══ TOP 5 POR DELITO ═══════════════════════════════════════════════ -->
  <section class="section wrap" id="ranking">
    <h2 class="section__title">Top 5 ciudades por delito · tasa x100.000 hab.</h2>
    <p class="section__byline">Policía Nacional (SIEDCO) · proyección ene-abr 2026 × 3</p>

    <div class="top5-grid" id="top5-grid"></div>

    <p class="cifras-mapa-nota" style="margin-top:1.25rem">
      Tasa proyectada = casos ene-abr × 3 ÷ pob. 2026 × 100.000 hab. · Policía Nacional (SIEDCO) ·
      Hurto automotores: 33/38 municipios.
    </p>
  </section>


<style>
/* ── Anclas ───────────────────────────────────────────────────────────────── */
.cifras-anclas {
  display: flex; align-items: center; gap: 0.5rem 1rem; flex-wrap: wrap;
  padding: 0.65rem 0; border-bottom: 1px solid var(--border);
  font-size: 0.75rem;
}
.cifras-anclas__label {
  font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
  color: var(--ink-soft); margin-right: 0.25rem; white-space: nowrap;
}
.cifras-ancla {
  color: var(--ink-soft); text-decoration: none; padding: 0.2rem 0.55rem;
  border: 1px solid transparent; border-radius: 6px; transition: all 0.15s; white-space: nowrap;
}
.cifras-ancla:hover { border-color: rgba(230,179,0,0.4); color: var(--accent); }

/* ── Hero ─────────────────────────────────────────────────────────────────── */
.cifras-hero {
  background: linear-gradient(180deg, rgba(5,5,8,0) 0%, var(--bg) 100%), var(--surface);
  border-bottom: 1px solid var(--border); padding: 3.5rem 0 2.5rem;
}
.cifras-hero__inner { max-width: 900px; }
.cifras-hero__kicker {
  font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--accent); margin-bottom: 0.5rem;
}
.cifras-hero__title {
  font-family: var(--font-display); font-size: clamp(2.2rem, 5vw, 3.5rem);
  font-weight: 900; line-height: 1.1; color: var(--ink); margin-bottom: 0.75rem;
}
.cifras-hero__sub {
  font-size: 1rem; color: var(--ink-soft); max-width: 680px;
  margin-bottom: 2.5rem; line-height: 1.6;
}
.cifras-kpis {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(185px, 1fr));
  gap: 1.25rem; margin-bottom: 2rem;
}
.cifras-kpi {
  background: var(--surface-2); border: 1px solid var(--border);
  border-top: 3px solid var(--accent); border-radius: var(--radius);
  padding: 1.25rem 1.5rem; display: flex; flex-direction: column; gap: 0.2rem;
}
.cifras-kpi__num {
  font-family: var(--font-display); font-size: clamp(1.8rem, 3.5vw, 2.6rem);
  font-weight: 900; color: var(--ink); line-height: 1; font-variant-numeric: tabular-nums;
}
.cifras-kpi__label {
  font-size: 0.78rem; font-weight: 700; color: var(--ink);
  text-transform: uppercase; letter-spacing: 0.04em; margin-top: 0.35rem;
}
.cifras-kpi__sub { font-size: 0.7rem; color: var(--ink-soft); line-height: 1.4; }
.cifras-corte {
  display: flex; flex-wrap: wrap; gap: 0.4rem 0.75rem;
  font-size: 0.75rem; color: var(--ink-soft); align-items: center;
}
.cifras-corte__sep { opacity: 0.4; }
.cifras-corte strong { color: var(--ink); }

/* ── Aviso ────────────────────────────────────────────────────────────────── */
.cifras-aviso {
  background: rgba(230,179,0,0.07); border: 1px solid rgba(230,179,0,0.25);
  border-left: 4px solid var(--accent); border-radius: var(--radius);
  padding: 1rem 1.25rem; font-size: 0.82rem; color: var(--ink-soft); line-height: 1.6;
}
.cifras-aviso strong, .cifras-aviso em { color: var(--ink); }

/* ── Indicadores ──────────────────────────────────────────────────────────── */
.cifras-ind-bloque { margin-bottom: 1.75rem; }
.cifras-ind-bloque__label {
  font-size: 0.72rem; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.08em; color: var(--accent); margin-bottom: 0.75rem;
}
.cifras-ind-cards {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 1rem; min-height: 140px;
}
.cifras-ind-card {
  background: var(--surface); border: 1px solid var(--border);
  border-top: 3px solid var(--accent); border-radius: var(--radius);
  padding: 1.1rem 1.25rem 0.9rem;
  display: flex; flex-direction: column; gap: 0.15rem;
  position: relative; overflow: hidden;
}
.cifras-ind-card::before {
  content: ""; position: absolute; top: -40px; left: -40px;
  width: 130px; height: 130px;
  background: radial-gradient(circle, rgba(230,179,0,0.08) 0%, transparent 70%);
  opacity: 0; transition: opacity 0.3s;
}
.cifras-ind-card:hover::before { opacity: 1; }
.cifras-ind-card__tipo {
  font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.06em; color: var(--ink-soft); margin-bottom: 0.25rem;
}
.cifras-ind-card__num {
  font-family: var(--font-display); font-size: clamp(1.6rem, 3vw, 2.2rem);
  font-weight: 900; color: var(--ink); line-height: 1.05; font-variant-numeric: tabular-nums;
}
.cifras-ind-card__num .sin-dato {
  font-size: 0.95rem; font-weight: 600; color: var(--ink-soft); font-family: var(--font-body);
}
.cifras-ind-card__var { font-size: 0.82rem; font-weight: 700; margin-top: 0.2rem; }
.cifras-ind-card__var.sube  { color: #c0553b; }
.cifras-ind-card__var.baja  { color: #3d8a6b; }
.cifras-ind-card__var.neutro{ color: var(--ink-soft); }
.cifras-ind-card__var.base-p { font-size: 0.72rem; font-weight: 400; color: var(--ink-soft); font-style: italic; }
.cifras-ind-card__tasa { font-size: 0.72rem; color: var(--ink-soft); line-height: 1.4; margin-top: 0.15rem; }
.cifras-ind-card__footer {
  display: flex; justify-content: space-between; font-size: 0.65rem; color: var(--ink-soft);
  margin-top: auto; padding-top: 0.6rem; border-top: 1px solid var(--border); opacity: 0.7;
}
.cifras-selector-row { display: flex; align-items: center; gap: 0.75rem; margin: 0.5rem 0 1.5rem; }
.cifras-selector-label { font-size: 0.78rem; font-weight: 700; color: var(--ink-soft); white-space: nowrap; }
.cifras-selector {
  background: var(--surface-2); border: 1px solid rgba(230,179,0,0.35);
  border-radius: 8px; color: var(--ink); font-family: var(--font-body);
  font-size: 0.85rem; padding: 0.45rem 0.85rem; cursor: pointer; flex: 1; max-width: 340px;
}
.cifras-selector:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 2px rgba(230,179,0,0.2); }

/* ── Mapa ─────────────────────────────────────────────────────────────────── */
.cifras-mapa-filtros {
  display: flex; align-items: flex-start; gap: 0.85rem; margin-bottom: 1rem; flex-wrap: wrap;
}
.cifras-mapa-filtros__label {
  font-size: 0.75rem; font-weight: 700; color: var(--ink-soft);
  text-transform: uppercase; letter-spacing: 0.06em; padding-top: 0.35rem;
}
.cifras-mapa-pills { display: flex; gap: 0.5rem; flex-wrap: wrap; }
.cifras-pill {
  background: var(--surface-2); border: 1px solid var(--border); border-radius: 8px;
  color: var(--ink-soft); font-size: 0.78rem; font-weight: 600;
  padding: 0.35rem 0.85rem; cursor: pointer; transition: all 0.18s;
}
.cifras-pill:hover { border-color: rgba(230,179,0,0.5); color: var(--ink); }
.cifras-pill.active { background: rgba(230,179,0,0.15); border-color: var(--accent); color: var(--accent); }
.cifras-mapa-wrap { border-radius: var(--radius); overflow: hidden; border: 1px solid var(--border); margin-bottom: 0.75rem; }
#cifras-mapa { height: 580px; width: 100%; background: var(--surface-2); }
:global(.leaflet-container)              { background: #1a2030 !important; font-family: var(--font-body) !important; }
:global(.leaflet-popup-content-wrapper) { background: #fff !important; color: #1a2030 !important; border: 1px solid rgba(0,0,0,0.12) !important; border-radius: 10px !important; box-shadow: 0 4px 20px rgba(0,0,0,0.18) !important; }
:global(.leaflet-popup-tip) { background: #fff !important; }
:global(.leaflet-popup-tip)             { background: #1e2535 !important; }
:global(.leaflet-popup-close-button)    { color: #8892a4 !important; }
:global(.leaflet-control-zoom a)        { background: #1e2535 !important; color: #f0f4f8 !important; border-color: rgba(255,255,255,0.1) !important; }
:global(.leaflet-control-attribution)   { background: rgba(13,17,23,0.75) !important; color: #8892a4 !important; font-size: 0.6rem !important; }
:global(.leaflet-control-attribution a){ color: #e6b300 !important; }
.cifras-mapa-leyenda {
  display: flex; flex-wrap: wrap; gap: 0.5rem 1rem; align-items: center;
  margin-bottom: 0.75rem; font-size: 0.72rem; color: var(--ink-soft);
}
.cifras-mapa-leyenda-item { display: flex; align-items: center; gap: 0.35rem; }
.cifras-mapa-leyenda-dot  { width: 14px; height: 14px; border-radius: 50%; flex-shrink: 0; border: 1px solid rgba(255,255,255,0.2); }
.cifras-mapa-nota { font-size: 0.72rem; color: var(--ink-soft); line-height: 1.6; margin-top: 0.25rem; }

/* ── Top 5 grid (container scoped; internos con :global) ─────────────────── */
.top5-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
}

:global(.t5-panel) {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--radius); overflow: hidden;
}
:global(.t5-head) {
  background: rgba(255,255,255,0.03);
  border-bottom: 1px solid var(--border);
  padding: 0.6rem 0.9rem;
}
:global(.t5-label) {
  font-size: 0.66rem; font-weight: 800; text-transform: uppercase;
  letter-spacing: 0.07em; color: var(--accent);
}
:global(.t5-row) {
  display: grid;
  grid-template-columns: 1.5rem 1fr 48px auto;
  gap: 0.45rem;
  padding: 0.42rem 0.9rem;
  border-bottom: 1px solid rgba(255,255,255,0.035);
  align-items: center;
}
:global(.t5-row:last-child) { border-bottom: none; }
:global(.t5-pos) {
  font-size: 0.69rem; font-weight: 700; color: var(--ink-soft);
  font-variant-numeric: tabular-nums; text-align: right;
}
:global(.t5-pos--1) { color: var(--accent); font-size: 0.78rem; }
:global(.t5-nombre) { font-size: 0.79rem; color: var(--ink); line-height: 1.25; }
:global(.t5-bar-wrap) {
  height: 5px; background: rgba(255,255,255,0.07);
  border-radius: 3px; overflow: hidden;
}
:global(.t5-bar) { height: 100%; border-radius: 3px; }
:global(.t5-tasa) {
  font-size: 0.73rem; font-weight: 700; color: var(--ink);
  font-variant-numeric: tabular-nums; text-align: right; white-space: nowrap;
}
:global(.t5-tasa small) { font-size: 0.58rem; font-weight: 400; color: var(--ink-soft); }

/* ── Cards por ciudad (container scoped, clases de cards con :global) ─────── */
.cifras-ciudad-bloque { margin-bottom: 1rem; }
.cifras-ciudad-nombre {
  font-size: 0.85rem; font-weight: 800; text-transform: uppercase;
  letter-spacing: 0.08em; color: var(--accent);
  margin-bottom: 0.9rem; display: flex; align-items: center; gap: 0.5rem;
}
.cifras-ciudad-nombre::before {
  content: ""; display: inline-block; width: 3px; height: 1em;
  background: var(--accent); border-radius: 2px;
}
.cifras-ciudad-cards {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.85rem;
}

/* :global porque el JS inserta este DOM dinámicamente */
:global(.ck) {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 1rem 1.15rem 0.9rem;
  display: flex; flex-direction: column; gap: 0.3rem;
  border-top: 2px solid var(--border);
  transition: border-color 0.15s, background 0.15s;
  position: relative; overflow: hidden;
}
:global(.ck::before) {
  content: ""; position: absolute; left: 0; top: 0; bottom: 0;
  width: 3px; background: var(--accent); border-radius: 0;
}
:global(.ck__tipo) {
  font-size: 0.65rem; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.07em; color: var(--ink-soft); margin-left: 0.1rem;
}
:global(.ck__main) {
  display: flex; align-items: baseline; gap: 0.55rem; flex-wrap: wrap;
  margin-top: 0.1rem;
}
:global(.ck__num) {
  font-family: var(--font-display); font-size: clamp(1.4rem, 2.2vw, 1.85rem);
  font-weight: 900; color: var(--ink); line-height: 1;
  font-variant-numeric: tabular-nums;
}
:global(.ck__num .sin-dato) {
  font-size: 0.9rem; font-weight: 500; color: var(--ink-soft);
  font-family: var(--font-body);
}
:global(.ck__badge) {
  font-size: 0.7rem; font-weight: 700;
  padding: 0.2em 0.6em; border-radius: 5px; white-space: nowrap;
  line-height: 1.4;
}
:global(.ck__badge--sube)  { background: rgba(192,85,59,.18);  color: #e07060; }
:global(.ck__badge--baja)  { background: rgba(61,138,107,.18); color: #5aaa88; }
:global(.ck__badge--neutro){ background: rgba(255,255,255,.06); color: var(--ink-soft); }
:global(.ck__badge--warn)  { background: rgba(230,179,0,.12);  color: var(--accent); font-size: 0.62rem; }
:global(.ck__tasa) {
  font-size: 0.72rem; color: var(--ink-soft); line-height: 1.45;
  margin-top: 0.15rem;
}
:global(.ck__tasa strong) { color: var(--ink); font-weight: 700; }

/* ── Responsive ───────────────────────────────────────────────────────────── */
@media (max-width: 700px) {
  .cifras-ciudad-cards { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 600px) {
  .cifras-kpis { grid-template-columns: repeat(2, 1fr); }
  .cifras-ind-cards { grid-template-columns: 1fr; }
  .cifras-ciudad-cards { grid-template-columns: repeat(2, 1fr); }
  #cifras-mapa { height: 380px; }
  .top5-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 420px) {
  .top5-grid { grid-template-columns: 1fr; }
}
</style>

<!-- Leaflet JS ──────────────────────────────────────────────────────────────── -->
<script is:inline src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js"></script>

<!-- App ──────────────────────────────────────────────────────────────────────── -->
<script is:inline define:vars={{ cityData }}>
/* ══════════════ HELPERS ════════════════════════════════════════════════════ */
function numCO(n) { return (n !== null && n !== undefined) ? n.toLocaleString("es-CO") : null; }

/* ══════════════ SELECTORES DE DELITO (6) ═══════════════════════════════════ */
function getTasa(c, d) {
  return d==='hom'?c.htp : d==='hur'?c.utp : d==='ext'?c.etp :
         d==='res'?c.rtp : d==='vif'?c.vitp : c.atp;
}
function getLabel(d) {
  return d==='hom'?'Homicidios' : d==='hur'?'Hurto a personas' : d==='ext'?'Extorsión' :
         d==='res'?'Hurto residencias' : d==='vif'?'Violencia intrafamiliar' : 'Hurto automotores';
}

/* ══════════════ ESCALA DE COLOR ════════════════════════════════════════════ */
const PAL = ["#f0d9a8","#e0a96a","#cc7840","#b54e2e","#8a2018"];
const SIN_COLOR = "#3a4050";

function quintiles(vals) {
  const s = [...vals].filter(v => v != null).sort((a,b) => a - b);
  if (!s.length) return [0,10,20,40,60,100];
  const q = i => s[Math.floor((i/5)*s.length)] ?? s[s.length-1];
  return [s[0], q(1), q(2), q(3), q(4), s[s.length-1]];
}
function palColor(t, brks) {
  if (t == null) return SIN_COLOR;
  for (let i = 0; i < PAL.length; i++) if (t <= brks[i+1]) return PAL[i];
  return PAL[PAL.length-1];
}

/* ══════════════ SELECTOR DE CIUDAD ════════════════════════════════════════ */
function kpiCard(tipo, n26, n25, vari, bp, tasa) {
  const ant = numCO(n25);
  const ts  = tasa != null ? tasa.toFixed(1).replace(".", ",") + " x100k" : null;
  const nl  = n26 != null ? numCO(n26) : '<span class="sin-dato">sin dato</span>';

  let badge;
  if (bp) {
    badge = '<span class="ck__badge ck__badge--warn">⚠ base insuf.</span>';
  } else if (vari != null) {
    const sign = vari > 0 ? "+" : "";
    const cls  = vari > 0 ? "sube" : vari < 0 ? "baja" : "neutro";
    const arr  = vari > 0 ? "↑" : vari < 0 ? "↓" : "→";
    badge = `<span class="ck__badge ck__badge--${cls}">${arr} ${sign}${vari.toFixed(1).replace(".", ",")}%</span>`;
  } else {
    badge = '<span class="ck__badge ck__badge--neutro">—</span>';
  }

  const partes = [ts ? `<strong>${ts}</strong>` : null, ant ? `vs. ${ant}` : null].filter(Boolean);
  const sub = partes.join(" · ") + (partes.length ? " <span style='opacity:.5'>ene-abr 2025</span>" : "—");

  return `<div class="ck">
    <span class="ck__tipo">${tipo}</span>
    <div class="ck__main"><span class="ck__num">${nl}</span>${badge}</div>
    <span class="ck__tasa">${sub}</span>
  </div>`;
}
function renderCity(c) {
  document.getElementById("ciudad-nombre").textContent = c.municipio;
  document.getElementById("ciudad-cards").innerHTML = [
    kpiCard("Homicidios",              c.h26,  c.h25,  c.hv,  c.hbp,  c.ht),
    kpiCard("Hurto a personas",        c.u26,  c.u25,  c.uv,  c.ubp,  c.ut),
    kpiCard("Extorsión",               c.e26,  c.e25,  c.ev,  c.ebp,  c.et),
    kpiCard("Hurto a residencias",     c.r26,  c.r25,  c.rv,  c.rbp,  c.rt),
    kpiCard("Violencia intrafamiliar", c.vi26, c.vi25, c.viv, c.vibp, c.vit),
    kpiCard("Hurto automotores",       c.a26,  c.a25,  c.av,  c.abp,  c.at),
  ].join("");
}
const sel = document.getElementById("ciudad-select");
const def = cityData.find(c => c.div === "11001") ?? cityData[0];
if (def) { sel.value = def.div; renderCity(def); }
sel.addEventListener("change", () => {
  const c = cityData.find(c => c.div === sel.value);
  if (c) renderCity(c);
});

/* ══════════════ MAPA ═══════════════════════════════════════════════════════ */
if (typeof L === 'undefined') {
  document.getElementById('cifras-mapa').innerHTML =
    '<p style="display:flex;align-items:center;justify-content:center;height:100%;color:#8892a4;font-size:.85rem">El mapa no pudo cargar — verifica tu conexión y recarga la página.</p>';
}
const map = typeof L !== 'undefined' && L.map("cifras-mapa", {
  center: [4.5, -74.5], zoom: 5, scrollWheelZoom: false,
  zoomControl: true,
});
if (map) {
  L.tileLayer("https://{s}.basemaps.cartocdn.com/rastertiles/voyager_nolabels/{z}/{x}/{y}{r}.png", {
    attribution: '© <a href="https://carto.com/">CartoDB</a> · © <a href="https://osm.org/copyright">OSM</a>',
    maxZoom: 14,
  }).addTo(map);
}
const mLayer = map ? L.layerGroup().addTo(map) : null;

// Control "Ver todas las ciudades"
if (map) {
  const FitControl = L.Control.extend({
    options: { position: 'topright' },
    onAdd() {
      const btn = L.DomUtil.create('button', '');
      btn.innerHTML = '⊞ Ver todas las ciudades';
      btn.style.cssText = 'background:rgba(255,255,255,.92);color:#334;border:1px solid rgba(0,0,0,.18);border-radius:6px;padding:6px 11px;font-size:.7rem;font-weight:700;cursor:pointer;font-family:inherit;letter-spacing:.04em;white-space:nowrap;box-shadow:0 2px 6px rgba(0,0,0,.15);';
      L.DomEvent.on(btn, 'click', function(e) {
        L.DomEvent.stopPropagation(e);
        L.DomEvent.preventDefault(e);
        const pts = cityData.filter(c => c.lat != null).map(c => [c.lat, c.lng]);
        if (pts.length) map.fitBounds(L.latLngBounds(pts), { padding: [50, 50] });
      });
      return btn;
    }
  });
  new FitControl().addTo(map);
}

function renderMapa(d) {
  if (!map) return;
  if (mLayer) mLayer.clearLayers();

  const brks = quintiles(cityData.map(c => getTasa(c, d)));
  const maxT = cityData.reduce((m, c) => Math.max(m, getTasa(c, d) ?? 0), 0) || 1;

  // ── Burbujas proporcionales ────────────────────────────────────────────
  cityData.forEach(c => {
    if (c.lat == null) return;
    const t   = getTasa(c, d);
    const col = palColor(t, brks);
    // radio: raíz cuadrada para no exagerar los extremos, mín 4px
    const r   = t != null ? Math.max(4, Math.sqrt(t / maxT) * 22) : 3;
    L.circleMarker([c.lat, c.lng], {
      radius:      r,
      fillColor:   t != null ? col : SIN_COLOR,
      color:       'rgba(255,255,255,0.8)',
      weight:      1.5,
      fillOpacity: t != null ? 0.88 : 0.35,
    }).bindPopup(
      `<div style="min-width:170px;line-height:1.65;color:#1a2030">
        <strong style="font-size:.95rem">${c.municipio}</strong><br>
        <span style="font-size:.67rem;color:#556;text-transform:uppercase;letter-spacing:.05em">${getLabel(d)}</span>
        <hr style="border:none;border-top:1px solid rgba(0,0,0,.1);margin:5px 0">
        <span style="font-size:.83rem">Tasa proyectada:<br>
          ${t != null ? '<strong style="font-size:1rem">' + t.toFixed(1).replace('.',',') + '</strong> x100k' : '<em>sin dato</em>'}
        </span>
      </div>`,
      { maxWidth: 220 }
    ).addTo(mLayer);
  });

  // ── Leyenda quintil ────────────────────────────────────────────────────
  const items = PAL.map((col, i) => {
    const lo = i === 0 ? '0' : brks[i].toFixed(0);
    const hi = i === PAL.length - 1 ? brks[i+1].toFixed(0) + '+' : brks[i+1].toFixed(0);
    return `<div class="cifras-mapa-leyenda-item">
      <div class="cifras-mapa-leyenda-dot" style="background:${col}"></div>
      <span>${lo}–${hi}</span>
    </div>`;
  }).join('') + `<div class="cifras-mapa-leyenda-item">
    <div class="cifras-mapa-leyenda-dot" style="background:${SIN_COLOR}"></div>
    <span>sin dato</span>
  </div>`;
  document.getElementById("mapa-leyenda").innerHTML =
    `<span style="font-size:.67rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;margin-right:.4rem">Tasa x100k</span>` + items;
}

/* ══════════════ TOP 5 POR DELITO (estático al cargar) ══════════════════════ */
function renderTop5() {
  const DELITOS = ["hom", "hur", "ext", "res", "vif", "aut"];
  const html = DELITOS.map(function(d) {
    const brks = quintiles(cityData.map(function(c) { return getTasa(c, d); }));
    const top  = [...cityData]
      .filter(function(c) { return getTasa(c, d) != null; })
      .sort(function(a, b) { return getTasa(b, d) - getTasa(a, d); })
      .slice(0, 5);
    const maxT = top.length ? getTasa(top[0], d) : 1;

    const rows = top.map(function(c, i) {
      const t  = getTasa(c, d);
      const bw = maxT > 0 ? (t / maxT * 100).toFixed(1) : 0;
      const tStr = t.toFixed(1).replace(".", ",");
      return `<div class="t5-row">
        <span class="t5-pos${i === 0 ? " t5-pos--1" : ""}">${i + 1}</span>
        <span class="t5-nombre">${c.municipio}</span>
        <div class="t5-bar-wrap"><div class="t5-bar" style="width:${bw}%;background:${palColor(t, brks)}"></div></div>
        <span class="t5-tasa">${tStr} <small>x100k</small></span>
      </div>`;
    }).join("");

    return `<div class="t5-panel">
      <div class="t5-head"><span class="t5-label">${getLabel(d)}</span></div>
      ${rows}
    </div>`;
  }).join("");

  document.getElementById("top5-grid").innerHTML = html;
}

/* ══════════════ ESTADO COMPARTIDO Y FILTROS ════════════════════════════════ */
let activeDelito = "hom";

function updateAll(d) {
  renderMapa(d);
}

renderTop5();
updateAll(activeDelito);

document.querySelectorAll("[data-delito]").forEach(btn => {
  btn.addEventListener("click", () => {
    document.querySelectorAll("[data-delito]").forEach(b => b.classList.remove("active"));
    btn.classList.add("active");
    activeDelito = btn.dataset.delito;
    updateAll(activeDelito);
  });
});
</script>

</Layout>
