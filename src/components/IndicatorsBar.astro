---
import indicators from "../data/indicators.json";
import { formatCurrency, formatUSD, trendArrow } from "../lib/format";

const rows = [
  { label: "Dólar", value: indicators.dolar, trend: indicators.dolarTrend, prefix: "$", format: formatCurrency },
  { label: "Euro", value: indicators.euro, trend: indicators.euroTrend, prefix: "$", format: formatCurrency },
  { label: "TRM", value: indicators.trm, trend: indicators.trmTrend, prefix: "$", format: formatCurrency },
  { label: "Brent", value: indicators.brent, trend: indicators.brentTrend, prefix: "US$", format: formatUSD, unit: "/ barril" },
  { label: "Café (lb)", value: indicators.cafe, trend: indicators.cafeTrend, prefix: "US$", format: formatUSD, unit: "/ lb" },
];
---

<div class="indicators">
  {
    rows.map((row) => (
      <div class="indicator">
        <span class="indicator__label">{row.label}</span>
        <span class="indicator__value">
          {row.prefix} {row.format(row.value)}
          {row.unit && <span class="indicator__unit">{row.unit}</span>}
        </span>
        <span class={`indicator__arrow indicator__arrow--${row.trend}`}>
          {trendArrow(row.trend)}
        </span>
      </div>
    ))
  }
</div>
