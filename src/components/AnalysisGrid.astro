---
import analisis from "../data/analisis.json";

const sections = [
  { key: "colombia", label: "Colombia", color: "blue", data: analisis.colombia },
  { key: "mundo", label: "Mundo", color: "mint", data: analisis.mundo },
];
---

<div class="analysis-grid">
  {
    sections.map((section) => (
      <div class={`analysis-card outlet--${section.color}`}>
        <h3 class="analysis-card__title">{section.label}</h3>
        {section.data?.intro && <p class="analysis-card__intro">{section.data.intro}</p>}
        {
          section.data?.items?.map((item) => (
            <div class="analysis-card__item">
              <span class="analysis-card__category">{item.category}</span>
              <p>{item.text}</p>
            </div>
          ))
        }
      </div>
    ))
  }
</div>
